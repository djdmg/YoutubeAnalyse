{% extends 'base.html.twig' %}

{% block title %}Dashboard — YouTube Analyse{% endblock %}

{% block body %}

{% if not is_connected %}
<div class="connect-card">
    <div class="connect-icon">
        <i class="fab fa-youtube"></i>
    </div>
    <h1>YouTube Analyse</h1>
    <p>Connecte ta chaîne YouTube pour commencer l'analyse.</p>
    <div class="feature-list">
        <div class="feature-item"><i class="fas fa-chart-bar"></i> Vues & Watch Time</div>
        <div class="feature-item"><i class="fas fa-users"></i> Évolution des abonnés</div>
        <div class="feature-item"><i class="fas fa-euro-sign"></i> Revenus AdSense</div>
        <div class="feature-item"><i class="fas fa-trophy"></i> Top vidéos & CTR</div>
    </div>
    <a href="{{ path('auth_google') }}" class="btn-connect">
        <i class="fab fa-youtube"></i>
        Connecter ma chaîne YouTube
    </a>
    <p class="connect-note">
        <i class="fas fa-lock"></i>
        Tes données restent privées et stockées sur ta base de données.
    </p>
</div>

{% else %}
{# Header #}
<div class="dashboard-header">
    <div>
        <h1>
            <i class="fab fa-youtube" style="color:#ff0000"></i>
            {% if latest_stats %}
                {{ latest_stats.channelTitle }}
            {% else %}
                Tableau de bord
            {% endif %}
        </h1>
        {% if latest_stats %}
            <span class="last-sync">Dernière sync : {{ latest_stats.recordedAt|date('d/m/Y H:i') }}</span>
        {% endif %}
    </div>
    <div class="header-actions">
        <form method="post" action="{{ path('sync_data') }}" class="js-sync-form" style="display:inline">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-sync-alt"></i> Synchroniser
            </button>
        </form>
        <form method="post" action="{{ path('auth_google_revoke') }}" style="display:inline">
            <button type="submit" class="btn btn-outline">
                <i class="fas fa-sign-out-alt"></i> Déconnecter
            </button>
        </form>
    </div>
</div>

{% if not latest_stats %}
<div class="empty-state">
    <i class="fas fa-sync-alt fa-3x"></i>
    <h3>Aucune donnée</h3>
    <p>Clique sur <strong>Synchroniser</strong> pour récupérer les métriques de ta chaîne.</p>
</div>
{% else %}

{# KPI Cards #}
<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-icon views">
            <i class="fas fa-eye"></i>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.viewCount|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Vues totales</div>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon subscribers">
            <i class="fas fa-users"></i>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.subscriberCount|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Abonnés</div>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon videos">
            <i class="fas fa-video"></i>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.videoCount|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Vidéos publiées</div>
        </div>
    </div>

    {% if latest_stats.watchTimeMinutes %}
    <div class="kpi-card">
        <div class="kpi-icon watchtime">
            <i class="fas fa-clock"></i>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">{{ (latest_stats.watchTimeMinutes / 60)|number_format(0, ',', ' ') }}h</div>
            <div class="kpi-label">Watch Time (30j)</div>
        </div>
    </div>
    {% endif %}

    {% if latest_stats.likes %}
    <div class="kpi-card">
        <div class="kpi-icon likes">
            <i class="fas fa-thumbs-up"></i>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.likes|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Likes (30j)</div>
        </div>
    </div>
    {% endif %}
</div>

{# Charts #}
{% if chart_data.labels|length > 0 %}
<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-header">
            <h3><i class="fas fa-eye"></i> Vues journalières</h3>
            <div class="period-selector">
                <button class="period-btn active" data-days="30">30j</button>
                <button class="period-btn" data-days="90">90j</button>
            </div>
        </div>
        <canvas id="viewsChart" height="120"></canvas>
    </div>

    <div class="chart-card">
        <div class="chart-header">
            <h3><i class="fas fa-users"></i> Abonnés</h3>
        </div>
        <canvas id="subscribersChart" height="120"></canvas>
    </div>

    {% if chart_data.watchTime|filter(v => v > 0)|length > 0 %}
    <div class="chart-card">
        <div class="chart-header">
            <h3><i class="fas fa-clock"></i> Watch Time (heures)</h3>
        </div>
        <canvas id="watchTimeChart" height="120"></canvas>
    </div>
    {% endif %}
</div>
{% endif %}

{# Top Videos #}
{% if top_videos|length > 0 %}
<div class="section-card">
    <div class="section-header">
        <h3><i class="fas fa-trophy"></i> Top 10 vidéos</h3>
        <a href="{{ path('videos') }}" class="btn btn-outline btn-sm">
            Voir tout <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div class="video-list">
        {% for video in top_videos %}
        <div class="video-item">
            <div class="video-rank">{{ loop.index }}</div>
            {% if video.thumbnailUrl %}
            <img src="{{ video.thumbnailUrl }}" alt="{{ video.title }}" class="video-thumb" loading="lazy">
            {% else %}
            <div class="video-thumb-placeholder"><i class="fas fa-video"></i></div>
            {% endif %}
            <div class="video-info">
                <div class="video-title">{{ video.title }}</div>
                <div class="video-meta">
                    {% if video.publishedAt %}
                    <span><i class="fas fa-calendar"></i> {{ video.publishedAt|date('d/m/Y') }}</span>
                    {% endif %}
                    {% if video.duration %}
                    <span><i class="fas fa-clock"></i> {{ video.duration|replace({'PT': '', 'H': 'h ', 'M': 'm ', 'S': 's'}) }}</span>
                    {% endif %}
                </div>
            </div>
            <div class="video-stats">
                <div class="stat"><i class="fas fa-eye"></i> {{ video.viewCount|number_format(0, ',', ' ') }}</div>
                <div class="stat"><i class="fas fa-thumbs-up"></i> {{ video.likeCount|number_format(0, ',', ' ') }}</div>
                <div class="stat"><i class="fas fa-comment"></i> {{ video.commentCount|number_format(0, ',', ' ') }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% endif %} {# end latest_stats #}
{% endif %} {# end is_connected #}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if is_connected and chart_data.labels|length > 0 %}
    <script>
        const chartData = {{ chart_data|json_encode|raw }};
    </script>
    {{ encore_entry_script_tags('dashboard') }}
    {% endif %}
{% endblock %}
