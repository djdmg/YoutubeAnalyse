{% extends 'base.html.twig' %}

{% block title %}Dashboard — YouTube Analyse{% endblock %}

{% block body %}

{% if not is_connected %}
<div class="connect-card">
    <div class="connect-icon"><i class="fab fa-youtube"></i></div>
    <h1>YouTube Analyse</h1>
    <p>Connecte ta chaîne YouTube pour commencer l'analyse.</p>
    <div class="feature-list">
        <div class="feature-item"><i class="fas fa-chart-bar"></i> Vues &amp; Watch Time</div>
        <div class="feature-item"><i class="fas fa-users"></i> Évolution des abonnés</div>
        <div class="feature-item"><i class="fas fa-robot"></i> Analyses IA</div>
        <div class="feature-item"><i class="fas fa-trophy"></i> Top vidéos &amp; CTR</div>
    </div>
    <a href="{{ path('auth_google') }}" class="btn-connect">
        <i class="fab fa-youtube"></i> Connecter ma chaîne YouTube
    </a>
    <p class="connect-note"><i class="fas fa-lock"></i> Données privées, stockées sur ta base de données.</p>
</div>

{% else %}

{# ── Header ──────────────────────────────────────────────────────────── #}
<div class="dashboard-header">
    <div>
        <h1>
            <i class="fab fa-youtube" style="color:#ff0000"></i>
            {{ latest_stats ? latest_stats.channelTitle : 'Tableau de bord' }}
        </h1>
        {% if latest_stats %}
        <span class="last-sync">Dernière sync : {{ latest_stats.recordedAt|date('d/m/Y H:i') }}</span>
        {% endif %}
    </div>
    <div class="header-actions">
        <form method="post" action="{{ path('sync_data') }}" class="js-sync-form" style="display:inline">
            <button type="submit" class="btn btn-primary"><i class="fas fa-sync-alt"></i> Synchroniser</button>
        </form>
        <form method="post" action="{{ path('auth_google_revoke') }}" style="display:inline">
            <button type="submit" class="btn btn-outline"><i class="fas fa-sign-out-alt"></i> Déconnecter</button>
        </form>
    </div>
</div>

{% if not latest_stats %}
<div class="empty-state">
    <i class="fas fa-sync-alt fa-3x"></i>
    <h3>Aucune donnée</h3>
    <p>Clique sur <strong>Synchroniser</strong> pour récupérer les métriques de ta chaîne.</p>
</div>

{% else %}

{# ── À faire banner ──────────────────────────────────────────────────── #}
{% if actions_count > 0 %}
<a href="{{ path('analytics_alerts') }}" class="actions-banner">
    <i class="fas fa-exclamation-triangle" style="color:var(--yellow);font-size:18px;flex-shrink:0"></i>
    <div>
        <strong>{{ actions_count }} action{{ actions_count > 1 ? 's' : '' }} en attente</strong>
        <span style="color:var(--text-secondary);font-size:12px;margin-left:8px">Alertes et recommandations IA →</span>
    </div>
</a>
{% endif %}

{# ── Period selector + KPIs ──────────────────────────────────────────── #}
<div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap">
    <span style="font-size:13px;color:var(--text-muted)">Période :</span>
    <div class="period-selector" id="kpiPeriodSelector">
        <button class="period-btn active" data-days="7">7j</button>
        <button class="period-btn" data-days="30">30j</button>
        <button class="period-btn" data-days="90">90j</button>
    </div>
    <span style="font-size:12px;color:var(--text-muted)" id="periodCompareLabel">vs 30j précédents</span>
</div>

<div class="period-kpi-grid" id="periodKpiGrid">
    <div class="period-kpi-card">
        <div class="period-kpi-label"><i class="fas fa-eye" style="color:var(--blue)"></i> Vues</div>
        <div class="period-kpi-value" id="kpi-views">{{ period_stats.views|default(0)|number_format(0, ',', ' ') }}</div>
        <div class="period-kpi-delta" id="delta-views"><span class="delta-neutral">—</span></div>
    </div>
    <div class="period-kpi-card">
        <div class="period-kpi-label"><i class="fas fa-clock" style="color:var(--orange)"></i> Watch Time</div>
        <div class="period-kpi-value" id="kpi-watch">
            {% set wt = period_stats.watch_time|default(0) %}
            {{ wt >= 60 ? (wt / 60)|round(1) ~ 'h' : wt ~ ' min' }}
        </div>
        <div class="period-kpi-delta" id="delta-watch"><span class="delta-neutral">—</span></div>
    </div>
    <div class="period-kpi-card">
        <div class="period-kpi-label"><i class="fas fa-user-plus" style="color:var(--purple)"></i> Abonnés gagnés</div>
        <div class="period-kpi-value" id="kpi-subs">
            {% set s = period_stats.subscribers|default(0) %}
            {{ s >= 0 ? '+' : '' }}{{ s }}
        </div>
        <div class="period-kpi-delta" id="delta-subs"><span class="delta-neutral">—</span></div>
    </div>
    <div class="period-kpi-card">
        <div class="period-kpi-label"><i class="fas fa-percentage" style="color:var(--yellow)"></i> CTR moyen</div>
        <div class="period-kpi-value" id="kpi-ctr">
            {{ period_stats.avg_ctr is not null ? period_stats.avg_ctr|number_format(2) ~ '%' : '—' }}
        </div>
        <div class="period-kpi-delta" id="delta-ctr"><span class="delta-neutral">—</span></div>
    </div>
</div>

{# ── Channel totals (static) ─────────────────────────────────────────── #}
<div class="kpi-grid" style="margin-bottom:28px">
    <div class="kpi-card">
        <div class="kpi-icon subscribers"><i class="fas fa-users"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.subscriberCount|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Abonnés total</div>
        </div>
    </div>
    {% if total_revenue is not null %}
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(34,197,94,0.15);color:var(--green)"><i class="fas fa-euro-sign"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ total_revenue|number_format(2, ',', ' ') }} €</div>
            <div class="kpi-label">Revenu estimé (30j)</div>
        </div>
    </div>
    {% endif %}
    <div class="kpi-card">
        <div class="kpi-icon videos"><i class="fas fa-video"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.videoCount|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Vidéos publiées</div>
        </div>
    </div>
    {% if latest_stats.likes %}
    <div class="kpi-card">
        <div class="kpi-icon likes"><i class="fas fa-thumbs-up"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.likes|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Likes (30j)</div>
        </div>
    </div>
    {% endif %}
    {% if latest_stats.comments %}
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(34,197,94,0.15);color:var(--green)"><i class="fas fa-comment"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ latest_stats.comments|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Commentaires (30j)</div>
        </div>
    </div>
    {% endif %}
</div>

{# ── Charts ──────────────────────────────────────────────────────────── #}
{% if chart_data.labels|length > 0 %}
<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-header">
            <h3><i class="fas fa-eye"></i> Vues journalières</h3>
            <div class="period-selector">
                <button class="period-btn active" data-days="30">30j</button>
                <button class="period-btn" data-days="90">90j</button>
            </div>
        </div>
        <canvas id="viewsChart" height="120"></canvas>
    </div>
    <div class="chart-card">
        <div class="chart-header"><h3><i class="fas fa-users"></i> Abonnés</h3></div>
        <canvas id="subscribersChart" height="120"></canvas>
    </div>
    {% if chart_data.watchTime|filter(v => v > 0)|length > 0 %}
    <div class="chart-card">
        <div class="chart-header"><h3><i class="fas fa-clock"></i> Watch Time (heures)</h3></div>
        <canvas id="watchTimeChart" height="120"></canvas>
    </div>
    {% endif %}
</div>
{% endif %}

{# ── Top Videos ──────────────────────────────────────────────────────── #}
{% if top_videos|length > 0 %}
<div class="section-card">
    <div class="section-header">
        <h3><i class="fas fa-trophy"></i> Top vidéos</h3>
        <a href="{{ path('analytics_videos') }}" class="btn btn-outline btn-sm">
            Analytics <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div class="video-list">
        {% for video in top_videos %}
        <div class="video-item">
            <div class="video-rank">{{ loop.index }}</div>
            {% if video.thumbnailUrl %}
            <img src="{{ video.thumbnailUrl }}" alt="{{ video.title }}" class="video-thumb" loading="lazy">
            {% else %}
            <div class="video-thumb-placeholder"><i class="fas fa-video"></i></div>
            {% endif %}
            <div class="video-info">
                <div class="video-title">{{ video.title }}</div>
                <div class="video-meta">
                    {% if video.publishedAt %}
                    <span><i class="fas fa-calendar"></i> {{ video.publishedAt|date('d/m/Y') }}</span>
                    {% endif %}
                    {% if video.duration %}
                    <span><i class="fas fa-clock"></i> {{ video.duration|replace({'PT': '', 'H': 'h ', 'M': 'm ', 'S': 's'}) }}</span>
                    {% endif %}
                </div>
            </div>
            <div class="video-stats">
                <div class="stat"><i class="fas fa-eye"></i> {{ video.viewCount|number_format(0, ',', ' ') }}</div>
                <div class="stat"><i class="fas fa-thumbs-up"></i> {{ video.likeCount|number_format(0, ',', ' ') }}</div>
                <div class="stat"><i class="fas fa-comment"></i> {{ video.commentCount|number_format(0, ',', ' ') }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# ── Goals ───────────────────────────────────────────────────────────── #}
<div class="section-card" id="goalsSection" style="margin-top:28px">
    <div class="section-header">
        <h3><i class="fas fa-bullseye" style="color:var(--blue)"></i> Objectifs</h3>
        <button class="btn btn-outline btn-sm" onclick="document.getElementById('goalModal').style.display='flex'" type="button">
            <i class="fas fa-plus"></i> Ajouter
        </button>
    </div>

    {% if goals is defined and goals|length > 0 %}
    <div class="goals-list">
        {% for goal in goals %}
        {% set pct = goal.progressPercent %}
        {% set goalColor = pct >= 100 ? 'var(--green)' : (pct >= 50 ? 'var(--blue)' : 'var(--yellow)') %}
        <div class="goal-item" id="goal-{{ goal.id }}">
            <div class="goal-header">
                <div class="goal-info">
                    <span class="goal-label">{{ goal.label }}</span>
                    <span class="goal-type-badge">
                        {% if goal.type == 'subscribers' %}<i class="fas fa-users"></i> Abonnés
                        {% elseif goal.type == 'views' %}<i class="fas fa-eye"></i> Vues (30j)
                        {% else %}<i class="fas fa-clock"></i> Watch Time (30j)
                        {% endif %}
                    </span>
                </div>
                <div class="goal-meta">
                    <span style="font-size:13px;font-weight:600;color:{{ goalColor }}">{{ goal.currentValue|number_format(0, ',', ' ') }} / {{ goal.targetValue|number_format(0, ',', ' ') }}</span>
                    {% if goal.deadline %}
                    <span style="font-size:11px;color:var(--text-muted);margin-left:8px"><i class="fas fa-calendar"></i> {{ goal.deadline|date('d/m/Y') }}</span>
                    {% endif %}
                    <button class="btn-goal-delete" onclick="deleteGoal({{ goal.id }})" title="Supprimer" type="button">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <div class="goal-progress-bar-wrap">
                <div class="goal-progress-bar" style="width:{{ pct }}%;background:{{ goalColor }}"></div>
            </div>
            <div class="goal-pct" style="color:{{ goalColor }}">{{ pct }}%</div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="empty-state" style="padding:24px">
        <i class="fas fa-bullseye fa-2x" style="color:var(--text-muted)"></i>
        <p style="margin-top:8px;font-size:13px;color:var(--text-muted)">Aucun objectif défini. Clique sur <strong>Ajouter</strong> pour en créer un.</p>
    </div>
    {% endif %}
</div>

{# ── Goal Modal ──────────────────────────────────────────────────────── #}
<div id="goalModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);z-index:1000;align-items:center;justify-content:center">
    <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:12px;padding:28px;min-width:340px;max-width:480px;width:90%">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
            <h3 style="margin:0"><i class="fas fa-bullseye" style="color:var(--blue)"></i> Nouvel objectif</h3>
            <button type="button" onclick="document.getElementById('goalModal').style.display='none'" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:18px">&times;</button>
        </div>
        <form id="goalForm">
            <div class="form-group" style="margin-bottom:14px">
                <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Nom de l'objectif</label>
                <input type="text" id="goalLabel" placeholder="ex: 1 000 abonnés" style="width:100%;box-sizing:border-box;background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text-primary);font-size:14px">
            </div>
            <div class="form-group" style="margin-bottom:14px">
                <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Type</label>
                <select id="goalType" style="width:100%;box-sizing:border-box;background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text-primary);font-size:14px">
                    <option value="subscribers">Abonnés</option>
                    <option value="views">Vues (30j)</option>
                    <option value="watch_time">Watch Time en minutes (30j)</option>
                </select>
            </div>
            <div class="form-group" style="margin-bottom:14px">
                <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Valeur cible</label>
                <input type="number" id="goalTarget" placeholder="ex: 1000" min="1" style="width:100%;box-sizing:border-box;background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text-primary);font-size:14px">
            </div>
            <div class="form-group" style="margin-bottom:20px">
                <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Date limite (optionnel)</label>
                <input type="date" id="goalDeadline" style="width:100%;box-sizing:border-box;background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text-primary);font-size:14px">
            </div>
            <div id="goalError" style="color:#ef4444;font-size:12px;margin-bottom:10px;display:none"></div>
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <button type="button" onclick="document.getElementById('goalModal').style.display='none'" class="btn btn-outline">Annuler</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Créer</button>
            </div>
        </form>
    </div>
</div>

<style>
.goals-list { display:flex; flex-direction:column; gap:12px; }
.goal-item { background:var(--bg-primary); border:1px solid var(--border); border-radius:8px; padding:14px 16px; }
.goal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.goal-info { display:flex; flex-direction:column; gap:4px; }
.goal-label { font-weight:600; font-size:14px; color:var(--text-primary); }
.goal-type-badge { font-size:11px; color:var(--text-muted); }
.goal-meta { display:flex; align-items:center; gap:8px; }
.btn-goal-delete { background:none; border:none; color:var(--text-muted); cursor:pointer; padding:2px 6px; border-radius:4px; font-size:13px; }
.btn-goal-delete:hover { color:#ef4444; background:rgba(239,68,68,.1); }
.goal-progress-bar-wrap { background:rgba(255,255,255,.06); border-radius:4px; height:8px; overflow:hidden; }
.goal-progress-bar { height:100%; border-radius:4px; transition:width .4s ease; }
.goal-pct { font-size:12px; text-align:right; margin-top:4px; font-weight:600; }
</style>

<script>
(function() {
    var form = document.getElementById('goalForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var errEl = document.getElementById('goalError');
            errEl.style.display = 'none';
            var payload = {
                label:       (document.getElementById('goalLabel').value || '').trim(),
                type:        document.getElementById('goalType').value,
                targetValue: document.getElementById('goalTarget').value,
                deadline:    document.getElementById('goalDeadline').value || null,
            };
            if (!payload.label) { errEl.textContent = 'Le nom est obligatoire.'; errEl.style.display = 'block'; return; }
            if (!payload.targetValue || parseInt(payload.targetValue) <= 0) { errEl.textContent = 'La valeur cible doit être positive.'; errEl.style.display = 'block'; return; }

            fetch('{{ path('goal_create') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(payload),
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) { errEl.textContent = data.error; errEl.style.display = 'block'; return; }
                document.getElementById('goalModal').style.display = 'none';
                window.location.reload();
            })
            .catch(function() { errEl.textContent = 'Erreur réseau.'; errEl.style.display = 'block'; });
        });
    }

    window.deleteGoal = function(id) {
        if (!confirm('Supprimer cet objectif ?')) return;
        fetch('/goals/' + id, {
            method: 'DELETE',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                var el = document.getElementById('goal-' + id);
                if (el) el.remove();
            }
        });
    };
})();
</script>

{% endif %}{# end latest_stats #}
{% endif %}{# end is_connected #}

{# ── Sync overlay ──────────────────────────────────────────────────────── #}
{% if is_connected %}
<div class="sync-overlay" id="syncOverlay">
    <div class="sync-spinner"></div>
    <div class="sync-overlay-text">Synchronisation en cours…</div>
    <div class="sync-overlay-sub">Récupération des métriques YouTube</div>
</div>
<div class="sync-toast" id="syncToast"></div>

<script>
(function() {
    var form = document.querySelector('.js-sync-form');
    if (!form) return;
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var overlay = document.getElementById('syncOverlay');
        var toast   = document.getElementById('syncToast');
        overlay.classList.add('visible');

        fetch('{{ path('sync_data') }}', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success || !data.jobId) {
                overlay.classList.remove('visible');
                toast.textContent = '✗ ' + (data.message || 'Erreur');
                toast.style.borderColor = 'rgba(239,68,68,.4)';
                toast.classList.add('show');
                setTimeout(function() { toast.classList.remove('show'); }, 3000);
                return;
            }
            // Poll until done
            var attempts = 0;
            var poll = setInterval(function() {
                attempts++;
                fetch('{{ path('sync_status', {jobId: '__JOB__'}) }}'.replace('__JOB__', data.jobId))
                    .then(function(r) { return r.json(); })
                    .then(function(status) {
                        if (status.status === 'pending' && attempts < 90) return;
                        clearInterval(poll);
                        overlay.classList.remove('visible');
                        var ok = status.status === 'done';
                        toast.textContent = ok ? '✓ ' + status.message : '✗ ' + (status.message || 'Erreur');
                        toast.style.borderColor = ok ? 'rgba(34,197,94,.4)' : 'rgba(239,68,68,.4)';
                        toast.classList.add('show');
                        setTimeout(function() {
                            toast.classList.remove('show');
                            if (ok) window.location.reload();
                        }, 2500);
                    })
                    .catch(function() { if (attempts >= 90) clearInterval(poll); });
            }, 2000);
        })
        .catch(function() {
            overlay.classList.remove('visible');
            toast.textContent = '✗ Erreur réseau';
            toast.style.borderColor = 'rgba(239,68,68,.4)';
            toast.classList.add('show');
            setTimeout(function() { toast.classList.remove('show'); }, 3000);
        });
    });
})();
</script>
{% endif %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if is_connected and chart_data.labels|length > 0 %}
    <script>const chartData = {{ chart_data|json_encode|raw }};</script>
    {{ encore_entry_script_tags('dashboard') }}
    {% endif %}
    {% if is_connected and latest_stats %}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var activeDays = 30;

        function renderDelta(elId, pct) {
            var el = document.getElementById(elId);
            if (!el) return;
            if (pct === null || pct === undefined) { el.innerHTML = '<span class="delta-neutral">—</span>'; return; }
            var cls  = pct > 0 ? 'delta-up' : (pct < 0 ? 'delta-down' : 'delta-neutral');
            var icon = pct > 0 ? '↑' : (pct < 0 ? '↓' : '');
            el.innerHTML = '<span class="' + cls + '">' + icon + ' ' + Math.abs(pct) + '%</span>';
        }

        function fmtViews(n) { return n.toLocaleString('fr-FR'); }
        function fmtWatch(min) { return min >= 60 ? Math.round(min / 60 * 10) / 10 + 'h' : min + ' min'; }
        function fmtSubs(n)  { return (n >= 0 ? '+' : '') + n; }
        function fmtCtr(v)   { return v !== null ? v.toFixed(2) + '%' : '—'; }

        function loadKpis(days) {
            document.querySelectorAll('#periodKpiGrid .period-kpi-value').forEach(function(el) { el.style.opacity = '0.4'; });
            fetch('/api/kpi-data?days=' + days, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                var kv = document.getElementById('kpi-views'),
                    kw = document.getElementById('kpi-watch'),
                    ks = document.getElementById('kpi-subs'),
                    kc = document.getElementById('kpi-ctr'),
                    lb = document.getElementById('periodCompareLabel');
                if (kv) { kv.textContent = fmtViews(d.views); kv.style.opacity = '1'; }
                if (kw) { kw.textContent = fmtWatch(d.watch_time); kw.style.opacity = '1'; }
                if (ks) { ks.textContent = fmtSubs(d.subscribers); ks.style.opacity = '1'; }
                if (kc) { kc.textContent = fmtCtr(d.avg_ctr); kc.style.opacity = '1'; }
                renderDelta('delta-views', d.delta_views);
                renderDelta('delta-watch', d.delta_watch);
                renderDelta('delta-subs', d.delta_subs);
                if (lb) lb.textContent = 'vs ' + days + 'j précédents';
            });
        }

        var selector = document.getElementById('kpiPeriodSelector');
        if (selector) {
            selector.addEventListener('click', function(e) {
                var btn = e.target.closest('.period-btn');
                if (!btn) return;
                var days = parseInt(btn.dataset.days);
                if (days === activeDays) return;
                activeDays = days;
                selector.querySelectorAll('.period-btn').forEach(function(b) { b.classList.toggle('active', b === btn); });
                loadKpis(days);
            });
        }
    });
    </script>
    {% endif %}
{% endblock %}
