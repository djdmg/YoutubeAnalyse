{% extends 'base.html.twig' %}
{% block title %}Messenger — File de messages{% endblock %}

{% block body %}

{# ── Header ──────────────────────────────────────────────────────────────── #}
<div class="dashboard-header">
    <div>
        <h1><i class="fas fa-paper-plane" style="color:#a78bfa"></i> Messenger</h1>
        <span class="last-sync" id="messengerMeta">File de traitement asynchrone · {{ logs|length }} entrées</span>
    </div>
    <div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap">
        <span id="refreshStatus" style="font-size:.75em;color:var(--text-muted)"></span>
        <button onclick="messengerRefresh()" class="btn btn-outline btn-sm" id="btnRefresh">
            <i class="fas fa-sync-alt"></i> Actualiser
        </button>
        <button onclick="clearLogs()" class="btn btn-sm" style="background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.3)" id="btnClear">
            <i class="fas fa-trash-alt"></i> Vider les logs
        </button>
        <a href="{{ path('admin_settings') }}" class="btn btn-outline btn-sm">
            <i class="fas fa-cog"></i> Paramètres
        </a>
    </div>
</div>

{# ── KPI cards ───────────────────────────────────────────────────────────── #}
{% set total = counts.processing + counts.pending + counts.success + counts.failed + counts.retry %}
{% set cards = [
    {label: 'En attente',    key: 'pending',    icon: 'fa-hourglass-half', color: '#94a3b8', glow: 'rgba(148,163,184,.15)'},
    {label: 'En traitement', key: 'processing', icon: 'fa-spinner',        color: '#a78bfa', glow: 'rgba(167,139,250,.15)'},
    {label: 'Réussis',       key: 'success',    icon: 'fa-check-circle',   color: '#22c55e', glow: 'rgba(34,197,94,.15)'},
    {label: 'En retry',      key: 'retry',      icon: 'fa-redo',           color: '#f59e0b', glow: 'rgba(245,158,11,.15)'},
    {label: 'Échoués',       key: 'failed',     icon: 'fa-times-circle',   color: '#ef4444', glow: 'rgba(239,68,68,.15)'},
] %}
<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;margin-bottom:1.5rem" id="kpiGrid">
{% for c in cards %}
{% set val = attribute(counts, c.key) %}
<div data-kpi="{{ c.key }}" style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:12px;padding:1.25rem 1.25rem 1rem;position:relative;overflow:hidden">
    <div style="position:absolute;top:0;left:0;right:0;height:3px;background:{{ c.color }};border-radius:12px 12px 0 0;opacity:{{ val > 0 ? '1' : '.25' }}" class="kpi-stripe"></div>
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:.75rem">
        <span style="font-size:.7em;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted)">{{ c.label }}</span>
        <div style="width:32px;height:32px;border-radius:8px;background:{{ c.glow }};display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="fas {{ c.icon }}" style="color:{{ c.color }};font-size:.85em"></i>
        </div>
    </div>
    <div class="kpi-value" style="font-size:2.25rem;font-weight:700;color:{{ val > 0 ? c.color : 'var(--text-muted)' }};line-height:1;margin-bottom:.6rem;font-variant-numeric:tabular-nums">{{ val }}</div>
    <div style="height:4px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden">
        <div class="kpi-bar" style="height:4px;width:{% if total > 0 %}{{ (val / total * 100)|round }}{% else %}0{% endif %}%;background:{{ c.color }};border-radius:4px;transition:width .4s ease;opacity:{{ val > 0 ? '.85' : '0' }}"></div>
    </div>
    <div class="kpi-pct" style="font-size:.7em;color:var(--text-muted);margin-top:.35rem">{% if total > 0 %}{{ (val / total * 100)|round }}%{% else %}—{% endif %} du total</div>
</div>
{% endfor %}
</div>

{# ── Worker hint ─────────────────────────────────────────────────────────── #}
<div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;padding:.75rem 1rem;background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.2);border-radius:8px;margin-bottom:1.5rem;font-size:.82em">
    <i class="fas fa-terminal" style="color:#a78bfa;flex-shrink:0"></i>
    <div>
        <span style="color:var(--text-secondary)">Worker :</span>
        <code style="background:rgba(0,0,0,.35);padding:.15rem .5rem;border-radius:4px;margin:0 .4rem">php bin/console messenger:consume async --time-limit=3600</code>
        <span style="color:var(--text-muted)">·</span>
        <span style="color:var(--text-secondary);margin-left:.4rem">Rejouer les échoués :</span>
        <code style="background:rgba(0,0,0,.35);padding:.15rem .5rem;border-radius:4px;margin-left:.4rem">messenger:failed:retry</code>
    </div>
    <span id="workerBadge" style="margin-left:auto;display:{{ (counts.processing + counts.pending + counts.retry) > 0 ? 'inline-flex' : 'none' }};background:rgba(167,139,250,.15);color:#a78bfa;padding:.2rem .6rem;border-radius:20px;font-size:.9em;font-weight:600;white-space:nowrap;align-items:center;gap:.3rem">
        <i class="fas fa-circle-notch fa-spin"></i><span id="workerBadgeText">{{ counts.processing + counts.pending + counts.retry }} en cours</span>
    </span>
</div>

{# ── Table ───────────────────────────────────────────────────────────────── #}
<div class="section-card" style="padding:0;overflow:hidden">
    <div style="padding:.875rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
        <h3 style="margin:0;font-size:.95rem"><i class="fas fa-list-ul" style="color:var(--text-muted);margin-right:.5rem"></i>Journal des messages</h3>
        <span style="font-size:.75em;color:var(--text-muted)" id="tableCaption">200 derniers · auto-refresh actif</span>
    </div>

    {% if logs is empty %}
    <div class="empty-state" style="padding:3rem" id="emptyState">
        <i class="fas fa-inbox fa-2x"></i>
        <h3>Aucun message</h3>
        <p>Les jobs apparaîtront ici dès qu'un message sera dispatché.</p>
    </div>
    <div style="overflow-x:auto;display:none" id="tableWrap">
    {% else %}
    <div style="overflow-x:auto" id="tableWrap">
    {% endif %}
    <table style="width:100%;border-collapse:collapse;font-size:.83em">
        <thead>
            <tr style="background:var(--bg-secondary)">
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap">#</th>
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em">Type</th>
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em">Statut</th>
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em">Durée</th>
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em">Créé</th>
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em">Terminé</th>
                <th style="padding:.6rem 1rem;text-align:left;font-weight:600;color:var(--text-muted);font-size:.75em;text-transform:uppercase;letter-spacing:.04em">Détails</th>
            </tr>
        </thead>
        <tbody id="messengerTbody">
        {% for log in logs %}
            {% set sc = {processing:'#a78bfa',pending:'#94a3b8',success:'#22c55e',failed:'#ef4444',retry:'#f59e0b'}[log.status] ?? '#94a3b8' %}
            {% set typeIcons = {
                'GenerateThumbnailMessage': 'fa-image',
                'SyncYouTubeMessage':       'fa-sync',
                'RunAiAnalysisMessage':     'fa-robot',
                'SyncSearchTermsMessage':   'fa-search'
            } %}
            {% set shortName = log.messageClass|split('\\')|last %}
            {% set icon = typeIcons[shortName] ?? 'fa-envelope' %}
            <tr style="border-bottom:1px solid var(--border)" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background=''">
                <td style="padding:.65rem 1rem;color:var(--text-muted);font-variant-numeric:tabular-nums">{{ log.id }}</td>
                <td style="padding:.65rem 1rem">
                    <div style="display:flex;align-items:center;gap:.5rem">
                        <span style="width:26px;height:26px;border-radius:6px;background:rgba(167,139,250,.12);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fas {{ icon }}" style="color:#a78bfa;font-size:.7em"></i>
                        </span>
                        <div>
                            <div style="font-weight:500;color:var(--text-primary)">{{ shortName|replace({'Message': ''}) }}</div>
                            <div style="font-size:.75em;color:var(--text-muted);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                {% for k,v in log.payload %}{% if loop.index <= 2 %}<span>{{ k }}:<b>{{ v|slice(0,20) }}</b></span>{% if not loop.last and loop.index < 2 %} · {% endif %}{% endif %}{% endfor %}
                            </div>
                        </div>
                    </div>
                </td>
                <td style="padding:.65rem 1rem">
                    <span style="display:inline-flex;align-items:center;gap:.3rem;background:{{ sc }}18;color:{{ sc }};padding:.2rem .65rem;border-radius:20px;font-size:.75em;font-weight:700;white-space:nowrap">
                        {% if log.status == 'processing' %}<i class="fas fa-circle-notch fa-spin" style="font-size:.7em"></i>
                        {% elseif log.status == 'pending' %}<i class="fas fa-hourglass-half" style="font-size:.7em"></i>
                        {% elseif log.status == 'success' %}<i class="fas fa-check" style="font-size:.7em"></i>
                        {% elseif log.status == 'failed' %}<i class="fas fa-times" style="font-size:.7em"></i>
                        {% elseif log.status == 'retry' %}<i class="fas fa-redo" style="font-size:.7em"></i>
                        {% endif %}
                        {% if log.status == 'processing' %}En traitement
                        {% elseif log.status == 'pending' %}En attente
                        {% elseif log.status == 'success' %}Réussi
                        {% elseif log.status == 'failed' %}Échoué
                        {% elseif log.status == 'retry' %}Retry
                        {% else %}{{ log.status|upper }}{% endif %}
                    </span>
                    {% if log.retryCount %}<span style="font-size:.7em;color:var(--text-muted);margin-left:.25rem">×{{ log.retryCount }}</span>{% endif %}
                </td>
                <td style="padding:.65rem 1rem;white-space:nowrap;font-variant-numeric:tabular-nums">
                    {% if log.durationMs %}
                        {% if log.durationMs >= 60000 %}<span style="color:#f59e0b">{{ (log.durationMs / 60000)|number_format(1) }}min</span>
                        {% elseif log.durationMs >= 1000 %}{{ (log.durationMs / 1000)|number_format(1) }}s
                        {% else %}<span style="color:var(--text-muted)">{{ log.durationMs }}ms</span>{% endif %}
                    {% else %}—{% endif %}
                </td>
                <td style="padding:.65rem 1rem;white-space:nowrap;color:var(--text-muted)">{{ log.createdAt|date('d/m H:i:s') }}</td>
                <td style="padding:.65rem 1rem;white-space:nowrap;color:var(--text-muted)">{{ log.finishedAt ? log.finishedAt|date('d/m H:i:s') : '—' }}</td>
                <td style="padding:.65rem 1rem;max-width:320px">
                    {% if log.error %}
                    <div style="display:flex;align-items:flex-start;gap:.4rem">
                        <span style="color:#ef4444;flex:1;line-height:1.4" title="{{ log.error }}">{{ log.error|slice(0,100) }}{% if log.error|length > 100 %}…{% endif %}</span>
                        <button onclick="copyError(this)" data-error="{{ log.error|e('html_attr') }}"
                            title="Copier l'erreur"
                            style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#ef4444;border-radius:5px;padding:.2rem .45rem;cursor:pointer;font-size:.8em;flex-shrink:0">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                    {% else %}<span style="color:var(--text-muted)">—</span>{% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
</div>

<script>
var DATA_URL = '{{ path('admin_messenger_data') }}';
var ICONS = { GenerateThumbnailMessage:'fa-image', SyncYouTubeMessage:'fa-sync', RunAiAnalysisMessage:'fa-robot', SyncSearchTermsMessage:'fa-search' };
var STATUS_COLOR = { processing:'#a78bfa', pending:'#94a3b8', success:'#22c55e', failed:'#ef4444', retry:'#f59e0b' };
var STATUS_ICON  = { processing:'fa-circle-notch fa-spin', pending:'fa-hourglass-half', success:'fa-check', failed:'fa-times', retry:'fa-redo' };
var STATUS_LABEL = { processing:'En traitement', pending:'En attente', success:'Réussi', failed:'Échoué', retry:'Retry' };
var KPI_META = {
    pending:    { label:'En attente',    color:'#94a3b8' },
    processing: { label:'En traitement', color:'#a78bfa' },
    success:    { label:'Réussis',       color:'#22c55e' },
    retry:      { label:'En retry',      color:'#f59e0b' },
    failed:     { label:'Échoués',       color:'#ef4444' }
};

function fmtDuration(ms) {
    if (!ms) return '—';
    if (ms >= 60000) return '<span style="color:#f59e0b">' + (ms/60000).toFixed(1) + 'min</span>';
    if (ms >= 1000)  return (ms/1000).toFixed(1) + 's';
    return '<span style="color:var(--text-muted)">' + ms + 'ms</span>';
}
function esc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function buildRow(log) {
    var sc     = STATUS_COLOR[log.status] || '#94a3b8';
    var si     = STATUS_ICON[log.status]  || 'fa-question';
    var sn     = log.shortName;
    var icon   = ICONS[sn] || 'fa-envelope';
    var label  = sn.replace('Message', '');
    var payloadHtml = log.payload.map(function(p, i) {
        return '<span>' + esc(p.k) + ':<b>' + esc(p.v) + '</b></span>' + (i < log.payload.length - 1 ? ' · ' : '');
    }).join('');
    var retryBadge = log.retryCount ? '<span style="font-size:.7em;color:var(--text-muted);margin-left:.25rem">×' + log.retryCount + '</span>' : '';
    var errHtml = log.error
        ? '<div style="display:flex;align-items:flex-start;gap:.4rem">'
          + '<span style="color:#ef4444;flex:1;line-height:1.4" title="' + esc(log.error) + '">'
          + esc(log.error.slice(0, 100)) + (log.error.length > 100 ? '…' : '') + '</span>'
          + '<button onclick="copyError(this)" data-error="' + esc(log.error) + '" title="Copier l\'erreur"'
          + ' style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#ef4444;border-radius:5px;padding:.2rem .45rem;cursor:pointer;font-size:.8em;flex-shrink:0">'
          + '<i class="fas fa-copy"></i></button></div>'
        : '<span style="color:var(--text-muted)">—</span>';

    return '<tr style="border-bottom:1px solid var(--border)" onmouseover="this.style.background=\'var(--bg-hover)\'" onmouseout="this.style.background=\'\'">'
        + '<td style="padding:.65rem 1rem;color:var(--text-muted);font-variant-numeric:tabular-nums">' + log.id + '</td>'
        + '<td style="padding:.65rem 1rem"><div style="display:flex;align-items:center;gap:.5rem">'
        + '<span style="width:26px;height:26px;border-radius:6px;background:rgba(167,139,250,.12);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">'
        + '<i class="fas ' + icon + '" style="color:#a78bfa;font-size:.7em"></i></span>'
        + '<div><div style="font-weight:500;color:var(--text-primary)">' + esc(label) + '</div>'
        + '<div style="font-size:.75em;color:var(--text-muted);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + payloadHtml + '</div>'
        + '</div></div></td>'
        + '<td style="padding:.65rem 1rem">'
        + '<span style="display:inline-flex;align-items:center;gap:.3rem;background:' + sc + '18;color:' + sc + ';padding:.2rem .65rem;border-radius:20px;font-size:.75em;font-weight:700;white-space:nowrap">'
        + '<i class="fas ' + si + '" style="font-size:.7em"></i> ' + (STATUS_LABEL[log.status] || log.status.toUpperCase()) + '</span>' + retryBadge + '</td>'
        + '<td style="padding:.65rem 1rem;white-space:nowrap;font-variant-numeric:tabular-nums">' + fmtDuration(log.durationMs) + '</td>'
        + '<td style="padding:.65rem 1rem;white-space:nowrap;color:var(--text-muted)">' + esc(log.createdAt) + '</td>'
        + '<td style="padding:.65rem 1rem;white-space:nowrap;color:var(--text-muted)">' + esc(log.finishedAt || '—') + '</td>'
        + '<td style="padding:.65rem 1rem;max-width:320px">' + errHtml + '</td>'
        + '</tr>';
}

function applyData(data) {
    var counts = data.counts;
    var total  = (counts.processing || 0) + (counts.pending || 0) + counts.success + counts.failed + counts.retry;
    var hasPending = (counts.processing || 0) + (counts.pending || 0) + counts.retry > 0;

    // Update KPI cards
    document.querySelectorAll('[data-kpi]').forEach(function(card) {
        var key  = card.getAttribute('data-kpi');
        var val  = counts[key] || 0;
        var meta = KPI_META[key];
        var pct  = total > 0 ? Math.round(val / total * 100) : 0;
        var color = meta.color;
        card.querySelector('.kpi-value').textContent = val;
        card.querySelector('.kpi-value').style.color = val > 0 ? color : 'var(--text-muted)';
        card.querySelector('.kpi-bar').style.width   = pct + '%';
        card.querySelector('.kpi-bar').style.opacity = val > 0 ? '.85' : '0';
        card.querySelector('.kpi-pct').textContent   = total > 0 ? pct + '% du total' : '—';
        card.querySelector('.kpi-stripe').style.opacity = val > 0 ? '1' : '.25';
    });

    // Worker badge
    var badge = document.getElementById('workerBadge');
    if (badge) {
        badge.style.display = hasPending ? 'inline-flex' : 'none';
        var bt = document.getElementById('workerBadgeText');
        if (bt) bt.textContent = ((counts.processing || 0) + (counts.pending || 0) + counts.retry) + ' en cours';
    }

    // Table
    var tbody = document.getElementById('messengerTbody');
    var empty = document.getElementById('emptyState');
    var wrap  = document.getElementById('tableWrap');
    if (tbody) tbody.innerHTML = data.logs.map(buildRow).join('');
    if (empty) empty.style.display = data.logs.length === 0 ? '' : 'none';
    if (wrap)  wrap.style.display  = data.logs.length === 0 ? 'none' : '';

    // Meta
    var meta = document.getElementById('messengerMeta');
    if (meta) meta.textContent = 'File de traitement asynchrone · ' + data.logs.length + ' entrées';

    var cap = document.getElementById('tableCaption');
    if (cap) cap.textContent = '200 derniers · ' + (hasPending ? 'auto-refresh actif' : 'à jour');

    updateRefreshStatus(hasPending);
    return hasPending;
}

var refreshTimer = null;
var countdown    = 0;
var cdInterval   = null;

function updateRefreshStatus(hasPending) {
    var el = document.getElementById('refreshStatus');
    if (!el) return;
    if (!hasPending) { el.textContent = 'À jour'; return; }
    el.textContent = 'Actualisation dans ' + countdown + 's…';
}

function scheduleNext(hasPending) {
    clearTimeout(refreshTimer);
    clearInterval(cdInterval);
    var delay = hasPending ? 10 : 30;
    countdown = delay;
    var el = document.getElementById('refreshStatus');

    cdInterval = setInterval(function() {
        countdown--;
        if (el) el.textContent = (hasPending ? 'Actualisation dans ' + countdown + 's…' : 'À jour');
    }, 1000);

    refreshTimer = setTimeout(messengerRefresh, delay * 1000);
}

window.messengerRefresh = function() {
    clearTimeout(refreshTimer);
    clearInterval(cdInterval);
    var btn = document.getElementById('btnRefresh');
    if (btn) btn.querySelector('i').className = 'fas fa-spinner fa-spin';

    fetch(DATA_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (btn) btn.querySelector('i').className = 'fas fa-sync-alt';
            var hasPending = applyData(data);
            scheduleNext(hasPending);
        })
        .catch(function() {
            if (btn) btn.querySelector('i').className = 'fas fa-sync-alt';
            scheduleNext(false);
        });
};

// Start
(function() {
    var hasPending = {{ (counts.processing + counts.pending + counts.retry) > 0 ? 'true' : 'false' }};
    scheduleNext(hasPending);
})();

function clearLogs() {
    openClearModal();
}

function openClearModal() {
    var overlay = document.getElementById('clearModalOverlay');
    overlay.style.display = 'flex';
    requestAnimationFrame(function() {
        overlay.classList.add('cm-visible');
    });
    document.getElementById('clearModalCancel').focus();
}

function closeClearModal() {
    var overlay = document.getElementById('clearModalOverlay');
    overlay.classList.remove('cm-visible');
    overlay.addEventListener('transitionend', function handler() {
        overlay.style.display = 'none';
        overlay.removeEventListener('transitionend', handler);
    });
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        var overlay = document.getElementById('clearModalOverlay');
        if (overlay && overlay.classList.contains('cm-visible')) closeClearModal();
    }
});

function confirmClearLogs() {
    var confirmBtn = document.getElementById('clearModalConfirm');
    var cancelBtn  = document.getElementById('clearModalCancel');
    confirmBtn.disabled = true;
    cancelBtn.disabled  = true;
    confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Vidage…';

    fetch('{{ path('admin_messenger_clear') }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        closeClearModal();
        if (data.success) {
            messengerRefresh();
        }
        confirmBtn.disabled = false;
        cancelBtn.disabled  = false;
        confirmBtn.innerHTML = '<i class="fas fa-trash-alt"></i> Tout supprimer';
    })
    .catch(function() {
        closeClearModal();
        confirmBtn.disabled = false;
        cancelBtn.disabled  = false;
        confirmBtn.innerHTML = '<i class="fas fa-trash-alt"></i> Tout supprimer';
    });
}

function copyError(btn) {
    var text = btn.getAttribute('data-error');
    var done = function() {
        var orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i>';
        btn.style.color = '#22c55e'; btn.style.borderColor = 'rgba(34,197,94,.3)';
        setTimeout(function() { btn.innerHTML = orig; btn.style.color = ''; btn.style.borderColor = ''; }, 1500);
    };
    if (navigator.clipboard) { navigator.clipboard.writeText(text).then(done); }
    else {
        var ta = document.createElement('textarea');
        ta.value = text; ta.style.cssText = 'position:fixed;opacity:0';
        document.body.appendChild(ta); ta.select(); document.execCommand('copy');
        document.body.removeChild(ta); done();
    }
}
</script>

