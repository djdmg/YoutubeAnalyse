{% extends 'base.html.twig' %}
{% block title %}Admin — Paramètres application{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1><i class="fas fa-cogs"></i> Paramètres application</h1>
        <span class="last-sync">Configuration globale</span>
    </div>
    <a href="{{ path('admin_users') }}" class="btn btn-outline"><i class="fas fa-users"></i> Utilisateurs</a>
</div>

{% for type, messages in app.flashes %}
  {% for msg in messages %}
    <div class="alert-banner alert-{{ type == 'success' ? 'success' : 'danger' }}" style="margin-bottom:1.25rem">
        <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>
        <div>{{ msg }}</div>
    </div>
  {% endfor %}
{% endfor %}

<div class="section-card" style="max-width:640px">
    <div class="section-header">
        <h3><i class="fab fa-telegram"></i> Notifications Telegram</h3>
        {% if telegram_token %}
            <span class="badge badge-green" style="background:rgba(34,197,94,.15);color:#86efac;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600">
                <i class="fas fa-circle" style="font-size:8px;vertical-align:middle;margin-right:4px"></i> Configuré
            </span>
        {% else %}
            <span style="background:rgba(239,68,68,.1);color:#fca5a5;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600">
                <i class="fas fa-circle" style="font-size:8px;vertical-align:middle;margin-right:4px"></i> Non configuré
            </span>
        {% endif %}
    </div>

    <p style="color:var(--text-secondary);font-size:13px;margin:0 0 20px">
        Token du bot Telegram utilisé pour envoyer des notifications à tous les utilisateurs qui ont renseigné leur Chat ID.
        Créez un bot via <strong>@BotFather</strong> sur Telegram pour obtenir ce token.
    </p>

    <form method="post" action="{{ path('admin_settings_save') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_settings') }}">
        <input type="hidden" name="section" value="telegram">

        <div class="form-field" style="margin-bottom:20px">
            <label style="display:block;font-size:13px;color:var(--text-secondary);margin-bottom:6px">
                Token bot Telegram
            </label>
            <input
                type="password"
                name="telegram_token"
                class="form-control"
                autocomplete="new-password"
                placeholder="{{ telegram_token ? '••••••••••••••••••••••••••••••••••••••••••••' : 'Ex : 123456789:ABCdefGhIJKlmNoPQRsTUVwXyZ' }}"
                style="font-family:monospace"
            >
            {% if telegram_token %}
            <span class="help-text">Un token est déjà enregistré. Laisser vide pour le conserver.</span>
            {% else %}
            <span class="help-text">Envoyez <code>/newbot</code> à <strong>@BotFather</strong> sur Telegram.</span>
            {% endif %}
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Enregistrer
        </button>
    </form>

    {% if telegram_token %}
    <div class="smtp-status active" style="margin-top:20px;border-color:#2ca5e0">
        <i class="fab fa-telegram" style="color:#2ca5e0"></i>
        Bot configuré — les utilisateurs avec un Chat ID recevront les notifications.
    </div>
    {% endif %}
</div>

{# ── AI Provider ─────────────────────────────────────────────────────────── #}
<div class="section-card" style="max-width:640px;margin-top:24px">
    <div class="section-header">
        <h3><i class="fas fa-robot"></i> Fournisseur IA</h3>
        <span style="background:{{ ai_provider == 'gemini' ? 'rgba(66,133,244,.15);color:#93c5fd' : 'rgba(139,92,246,.15);color:#c4b5fd' }};padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600">
            {{ ai_provider == 'gemini' ? 'Gemini (Google)' : 'Claude (Anthropic)' }}
        </span>
    </div>

    <p style="color:var(--text-secondary);font-size:13px;margin:0 0 20px">
        Choisissez le modèle IA utilisé pour toutes les analyses (titres, commentaires, anomalies, thumbnails…).
        Claude et Gemini utilisent les mêmes niveaux : <strong>Fast</strong> (haiku / flash), <strong>Balanced</strong> (sonnet / 1.5 pro), <strong>Full</strong> (sonnet / 2.5 pro).
    </p>

    <form method="post" action="{{ path('admin_settings_save') }}" id="aiProviderForm">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_settings') }}">
        <input type="hidden" name="section" value="ai">

        <div class="form-field" style="margin-bottom:20px">
            <label style="display:block;font-size:13px;color:var(--text-secondary);margin-bottom:10px">Fournisseur actif</label>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
                <label style="display:flex;align-items:center;gap:10px;padding:12px 20px;border:1px solid {{ ai_provider != 'gemini' ? 'rgba(139,92,246,.5)' : 'rgba(255,255,255,.1)' }};border-radius:10px;cursor:pointer;flex:1;min-width:160px;background:{{ ai_provider != 'gemini' ? 'rgba(139,92,246,.08)' : 'transparent' }}">
                    <input type="radio" name="ai_provider" value="claude" {{ ai_provider != 'gemini' ? 'checked' : '' }} onchange="toggleGeminiKey(this.value)">
                    <div>
                        <div style="font-weight:600;font-size:14px"><i class="fas fa-robot" style="color:#c4b5fd;margin-right:6px"></i>Claude</div>
                        <div style="font-size:11px;color:var(--text-muted)">Anthropic — clé dans .env</div>
                    </div>
                </label>
                <label style="display:flex;align-items:center;gap:10px;padding:12px 20px;border:1px solid {{ ai_provider == 'gemini' ? 'rgba(66,133,244,.5)' : 'rgba(255,255,255,.1)' }};border-radius:10px;cursor:pointer;flex:1;min-width:160px;background:{{ ai_provider == 'gemini' ? 'rgba(66,133,244,.08)' : 'transparent' }}">
                    <input type="radio" name="ai_provider" value="gemini" {{ ai_provider == 'gemini' ? 'checked' : '' }} onchange="toggleGeminiKey(this.value)">
                    <div>
                        <div style="font-weight:600;font-size:14px"><i class="fab fa-google" style="color:#93c5fd;margin-right:6px"></i>Gemini</div>
                        <div style="font-size:11px;color:var(--text-muted)">Google — clé configurée ici</div>
                    </div>
                </label>
            </div>
        </div>

        <div id="geminiKeyField" style="margin-bottom:20px;{{ ai_provider != 'gemini' ? 'display:none' : '' }}">
            <label style="display:block;font-size:13px;color:var(--text-secondary);margin-bottom:6px">
                Clé API Gemini
            </label>
            <input
                type="password"
                name="gemini_api_key"
                class="form-control"
                autocomplete="new-password"
                placeholder="{{ gemini_api_key ? '••••••••••••••••••••••••••••••••' : 'AIza…' }}"
                style="font-family:monospace"
            >
            {% if gemini_api_key %}
            <span class="help-text">Clé enregistrée. Laisser vide pour la conserver.</span>
            {% else %}
            <span class="help-text">Obtenez votre clé sur <strong>Google AI Studio</strong> → <em>Get API key</em>.</span>
            {% endif %}
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Enregistrer
        </button>
    </form>

    <div style="margin-top:20px;padding:14px;background:rgba(255,255,255,.03);border-radius:8px;font-size:12px;color:var(--text-muted);line-height:1.8">
        <strong style="color:var(--text-secondary)">Correspondance des niveaux</strong><br>
        Fast → <code>claude-haiku-4-5</code> ($0.80/$4 /1M) / <code>gemini-2.0-flash</code> ($0.10/$0.40 /1M)<br>
        Balanced → <code>claude-sonnet-4-6</code> ($3/$15 /1M) / <code>gemini-1.5-pro</code> ($1.25/$5 /1M)<br>
        Full → <code>claude-sonnet-4-20250514</code> ($3/$15 /1M) / <code>gemini-2.5-pro</code> ($1.25/$10 /1M)
    </div>
</div>

{# ── Modèles par tâche ───────────────────────────────────────────────────── #}
<div class="section-card" style="max-width:760px;margin-top:24px">
    <div class="section-header">
        <h3><i class="fas fa-sliders-h"></i> Modèle par tâche IA</h3>
        <button type="button" id="refreshModelsBtn" class="btn btn-outline btn-sm" onclick="loadModels(true)">
            <i class="fas fa-sync-alt" id="refreshIcon"></i> Actualiser les modèles
        </button>
    </div>
    <p style="color:var(--text-secondary);font-size:13px;margin:0 0 16px">
        Choisissez un modèle spécifique pour chaque tâche. Les alias <strong>fast/balanced/full</strong> s'adaptent automatiquement au fournisseur actif.
    </p>
    <div id="modelsLoading" style="text-align:center;padding:20px;color:var(--text-muted)">
        <i class="fas fa-spinner fa-spin"></i> Chargement des modèles…
    </div>
    <form method="post" action="{{ path('admin_settings_save') }}" id="taskModelsForm" style="display:none">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_settings') }}">
        <input type="hidden" name="section" value="models">
        <div id="taskModelsGrid" style="display:grid;gap:10px"></div>
        <div style="margin-top:16px">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Enregistrer les modèles
            </button>
        </div>
    </form>
</div>

<style>
.cs-wrap{position:relative}
.cs-trigger{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:9px 12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;cursor:pointer;user-select:none;transition:border-color .15s,background .15s}
.cs-trigger:hover{border-color:rgba(255,255,255,.22);background:rgba(255,255,255,.07)}
.cs-wrap.cs-open .cs-trigger{border-color:rgba(139,92,246,.55);background:rgba(139,92,246,.07)}
.cs-trigger-inner{display:flex;align-items:center;gap:7px;flex:1;min-width:0;overflow:hidden}
.cs-trigger-name{font-size:12px;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cs-arrow{color:var(--text-muted);font-size:10px;flex-shrink:0;transition:transform .15s}
.cs-wrap.cs-open .cs-arrow{transform:rotate(180deg)}
.cs-panel{position:absolute;top:calc(100% + 4px);left:0;right:0;background:#0f0f1a;border:1px solid rgba(255,255,255,.13);border-radius:10px;box-shadow:0 12px 32px rgba(0,0,0,.55);z-index:999;display:none;max-height:280px;overflow-y:auto}
.cs-wrap.cs-open .cs-panel{display:block}
.cs-group{padding:8px 12px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);border-top:1px solid rgba(255,255,255,.06)}
.cs-opt{display:flex;align-items:center;gap:8px;padding:8px 12px;cursor:pointer;transition:background .1s}
.cs-opt:hover{background:rgba(255,255,255,.05)}
.cs-opt.cs-selected{background:rgba(139,92,246,.1)}
.cs-opt-name{flex:1;font-size:12px;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cs-opt:hover .cs-opt-name,.cs-opt.cs-selected .cs-opt-name{color:var(--text-primary)}
.cs-badge{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;padding:2px 7px;border-radius:5px;flex-shrink:0}
.cs-badge-fast{background:rgba(34,197,94,.12);color:#86efac}
.cs-badge-balanced{background:rgba(139,92,246,.15);color:#c4b5fd}
.cs-badge-full{background:rgba(59,130,246,.15);color:#93c5fd}
.cs-price{font-size:10px;font-family:monospace;color:var(--text-muted);flex-shrink:0;white-space:nowrap}
</style>

<script>
var _savedTaskModels = {{ task_models|json_encode|raw }};

function loadModels(forceRefresh) {
    var btn  = document.getElementById('refreshModelsBtn');
    var icon = document.getElementById('refreshIcon');
    icon.className = 'fas fa-spinner fa-spin';
    btn.disabled = true;

    var url = '{{ path('admin_settings_models') }}' + (forceRefresh ? '?refresh=1' : '');
    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        icon.className = 'fas fa-sync-alt';
        btn.disabled = false;
        if (data.error) { alert('Erreur : ' + data.error); return; }
        renderTaskModels(data);
    })
    .catch(function(e) {
        icon.className = 'fas fa-sync-alt';
        btn.disabled = false;
        alert('Erreur réseau : ' + e.message);
    });
}

function makeBadge(tier) {
    if (!tier) return null;
    var el = document.createElement('span');
    el.className = 'cs-badge cs-badge-' + tier;
    el.textContent = tier;
    return el;
}

function makePrice(pricing) {
    if (!pricing) return null;
    var el = document.createElement('span');
    el.className = 'cs-price';
    el.textContent = '$' + pricing.in + ' / $' + pricing.out + ' /1M';
    return el;
}

function buildCustomSelect(name, allOptions, savedVal) {
    var wrap = document.createElement('div');
    wrap.className = 'cs-wrap';

    var hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = name;
    hidden.value = savedVal;

    var trigger = document.createElement('div');
    trigger.className = 'cs-trigger';
    var trigInner = document.createElement('div');
    trigInner.className = 'cs-trigger-inner';
    var arrow = document.createElement('span');
    arrow.className = 'cs-arrow';
    arrow.innerHTML = '<i class="fas fa-chevron-down"></i>';
    trigger.appendChild(trigInner);
    trigger.appendChild(arrow);

    var panel = document.createElement('div');
    panel.className = 'cs-panel';

    var allEntries = [{ id: '', name: '— Défaut du code —', tier: null, pricing: null, group: null }].concat(allOptions);
    var optEls = [];

    // Default option (no group header)
    (function() {
        var el = document.createElement('div');
        el.className = 'cs-opt' + (savedVal === '' ? ' cs-selected' : '');
        el.dataset.value = '';
        var nameEl = document.createElement('span');
        nameEl.className = 'cs-opt-name';
        nameEl.textContent = '— Défaut du code —';
        el.appendChild(nameEl);
        panel.appendChild(el);
        optEls.push({ el: el, entry: allEntries[0] });
    })();

    // Grouped options
    var groups = {};
    allOptions.forEach(function(o) { if (!groups[o.group]) groups[o.group] = []; groups[o.group].push(o); });
    Object.keys(groups).forEach(function(gName) {
        var gl = document.createElement('div');
        gl.className = 'cs-group';
        gl.textContent = gName;
        panel.appendChild(gl);
        groups[gName].forEach(function(o) {
            var el = document.createElement('div');
            el.className = 'cs-opt' + (o.id === savedVal ? ' cs-selected' : '');
            el.dataset.value = o.id;
            var nameEl = document.createElement('span');
            nameEl.className = 'cs-opt-name';
            nameEl.textContent = o.name;
            el.appendChild(nameEl);
            var b = makeBadge(o.tier); if (b) el.appendChild(b);
            var p = makePrice(o.pricing); if (p) el.appendChild(p);
            panel.appendChild(el);
            optEls.push({ el: el, entry: o });
        });
    });

    function updateTrigger(id) {
        var found = allEntries.find(function(e) { return e.id === id; }) || allEntries[0];
        trigInner.innerHTML = '';
        var nameEl = document.createElement('span');
        nameEl.className = 'cs-trigger-name';
        nameEl.textContent = found.name;
        trigInner.appendChild(nameEl);
        var b = makeBadge(found.tier); if (b) trigInner.appendChild(b);
        var p = makePrice(found.pricing); if (p) { p.style.fontSize = '10px'; trigInner.appendChild(p); }
        optEls.forEach(function(x) { x.el.classList.toggle('cs-selected', x.entry.id === id); });
    }

    updateTrigger(savedVal);

    trigger.addEventListener('click', function(e) {
        e.stopPropagation();
        var opening = !wrap.classList.contains('cs-open');
        document.querySelectorAll('.cs-wrap.cs-open').forEach(function(w) { w.classList.remove('cs-open'); });
        if (opening) wrap.classList.add('cs-open');
    });

    optEls.forEach(function(x) {
        x.el.addEventListener('click', function(e) {
            e.stopPropagation();
            hidden.value = x.entry.id;
            updateTrigger(x.entry.id);
            wrap.classList.remove('cs-open');
        });
    });

    wrap.appendChild(trigger);
    wrap.appendChild(panel);
    wrap.appendChild(hidden);
    return wrap;
}

document.addEventListener('click', function() {
    document.querySelectorAll('.cs-wrap.cs-open').forEach(function(w) { w.classList.remove('cs-open'); });
});

function renderTaskModels(data) {
    var grid = document.getElementById('taskModelsGrid');
    var form = document.getElementById('taskModelsForm');
    document.getElementById('modelsLoading').style.display = 'none';
    form.style.display = '';

    var allOptions = [];
    data.tiers.forEach(function(t) {
        allOptions.push({ id: t.id, name: t.name, tier: t.tier, pricing: null, group: 'Alias universels' });
    });
    data.models.forEach(function(m) {
        allOptions.push({ id: m.id, name: m.name, tier: m.tier, pricing: m.pricing, group: 'Modèles ' + data.provider });
    });

    var tasks = {{ ai_tasks_json|raw }};
    grid.innerHTML = '';

    tasks.forEach(function(task) {
        var savedVal = _savedTaskModels[task.value] || '';
        var row = document.createElement('div');
        row.style.cssText = 'display:grid;grid-template-columns:220px 1fr;align-items:center;gap:12px;padding:10px 12px;background:rgba(255,255,255,.03);border-radius:8px';

        var label = document.createElement('label');
        label.style.cssText = 'font-size:13px;font-weight:500;color:var(--text-primary)';
        label.textContent = task.label;

        row.appendChild(label);
        row.appendChild(buildCustomSelect('ai_model_' + task.value, allOptions, savedVal));
        grid.appendChild(row);
    });
}

document.addEventListener('DOMContentLoaded', function() { loadModels(); });
</script>

<script>
function toggleGeminiKey(val) {
    document.getElementById('geminiKeyField').style.display = val === 'gemini' ? '' : 'none';
}

document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('form[action="{{ path('admin_settings_save') }}"]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var btn = form.querySelector('button[type=submit]');
            var orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enregistrement…';

            var body = new URLSearchParams(new FormData(form)).toString();

            fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: body
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false;
                btn.innerHTML = orig;
                if (window.showToast) {
                    window.showToast(data.message || 'Enregistré.', data.success ? 'success' : 'error');
                } else {
                    var el = document.createElement('div');
                    el.className = 'alert alert-' + (data.success ? 'success' : 'danger');
                    el.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;min-width:260px';
                    el.innerHTML = '<i class="fas fa-check-circle"></i> ' + (data.message || 'Enregistré.');
                    document.body.appendChild(el);
                    setTimeout(function() { el.remove(); }, 3500);
                }
                if (data.success && data.reload_models) {
                    loadModels(true);
                }
            })
            .catch(function() {
                btn.disabled = false;
                btn.innerHTML = orig;
                alert('Erreur réseau.');
            });
        });
    });
});
</script>
{% endblock %}
