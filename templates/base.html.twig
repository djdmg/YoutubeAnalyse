<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}YouTube Analyse{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body class="bg-dark">

<nav class="navbar">
    <div class="navbar-brand">
        <i class="fab fa-youtube" style="color:#ff0000"></i>
        <span>YouTube Analyse</span>
    </div>
    {% if app.user %}
    <button class="navbar-toggle" id="navToggle" aria-label="Menu">
        <i class="fas fa-bars"></i>
    </button>
    {% endif %}
    <div class="navbar-links" id="navLinks">
        {% if app.user %}
        <a href="{{ path('dashboard') }}" class="{{ app.request.attributes.get('_route') == 'dashboard' ? 'active' : '' }}">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>
        <a href="{{ path('videos') }}" class="{{ app.request.attributes.get('_route') == 'videos' ? 'active' : '' }}">
            <i class="fas fa-video"></i> Vidéos
        </a>
        <a href="{{ path('analytics_videos') }}" class="{{ app.request.attributes.get('_route') starts with 'analytics_video' ? 'active' : '' }}">
            <i class="fas fa-chart-bar"></i> Analytics
        </a>
        <a href="{{ path('analytics_alerts') }}" class="{{ app.request.attributes.get('_route') == 'analytics_alerts' ? 'active' : '' }}">
            <i class="fas fa-tasks"></i> Actions
        </a>
        <a href="{{ path('analytics_ai_costs') }}" class="{{ app.request.attributes.get('_route') == 'analytics_ai_costs' ? 'active' : '' }}">
            <i class="fas fa-robot"></i> Coûts IA
        </a>
        <a href="{{ path('playlists_create') }}" class="{{ app.request.attributes.get('_route') starts with 'playlists' ? 'active' : '' }}">
            <i class="fas fa-list-ul"></i> Playlists IA
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_users') }}" class="{{ app.request.attributes.get('_route') == 'admin_users' ? 'active' : '' }}" style="{{ app.request.attributes.get('_route') != 'admin_users' ? 'color:var(--yellow)' : '' }}">
            <i class="fas fa-users-cog"></i> Admin
            {% if pending_approval_count is defined and pending_approval_count > 0 %}
            <span class="nav-badge">{{ pending_approval_count }}</span>
            {% endif %}
        </a>
        <a href="{{ path('admin_settings') }}" class="{{ app.request.attributes.get('_route') == 'admin_settings' ? 'active' : '' }}" style="{{ app.request.attributes.get('_route') != 'admin_settings' ? 'color:var(--yellow)' : '' }}">
            <i class="fas fa-cogs"></i> Paramètres
        </a>
        <a href="{{ path('admin_messenger') }}" class="{{ app.request.attributes.get('_route') == 'admin_messenger' ? 'active' : '' }}" style="{{ app.request.attributes.get('_route') != 'admin_messenger' ? 'color:var(--yellow)' : '' }}">
            <i class="fas fa-paper-plane"></i> Messenger
        </a>
        {% endif %}
        <div class="navbar-user">
            {% if app.user.avatarUrl %}
            <img src="{{ app.user.avatarUrl }}" alt="{{ app.user.displayName }}" class="user-avatar">
            {% else %}
            <div class="user-avatar-placeholder"><i class="fas fa-user"></i></div>
            {% endif %}
            <span class="user-name">{{ app.user.displayName }}</span>
            {# Multi-channel switcher — only shown if user has more than 1 token #}
            {% if app.user.googleTokens|length > 1 %}
            <div class="channel-switcher" id="channelSwitcher">
                <button type="button" class="btn-logout channel-switcher-btn" id="channelSwitcherBtn" title="Changer de chaîne">
                    <i class="fas fa-exchange-alt"></i>
                </button>
                <div class="channel-switcher-menu" id="channelSwitcherMenu">
                    {% for token in app.user.googleTokens %}
                    <form method="post" action="{{ path('channel_switch') }}">
                        <input type="hidden" name="channelId" value="{{ token.channelId }}">
                        <button type="submit" class="channel-switcher-item {{ token.channelId == app.user.activeChannelId ? 'active' : '' }}">
                            <i class="fab fa-youtube" style="color:#ff0000;margin-right:6px"></i>
                            {{ token.channelTitle ?? token.channelId }}
                            {% if token.channelId == app.user.activeChannelId %}
                            <i class="fas fa-check" style="margin-left:auto;color:var(--green)"></i>
                            {% endif %}
                        </button>
                    </form>
                    {% endfor %}
                </div>
            </div>
            <style>
            .channel-switcher { position:relative; display:inline-block; }
            .channel-switcher-menu { display:none; position:absolute; right:0; top:calc(100% + 6px); background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px; min-width:220px; box-shadow:0 8px 24px rgba(0,0,0,.4); z-index:200; padding:6px; }
            .channel-switcher-menu.open { display:block; }
            .channel-switcher-item { display:flex; align-items:center; width:100%; background:none; border:none; color:var(--text-primary); padding:8px 10px; border-radius:6px; cursor:pointer; font-size:13px; text-align:left; }
            .channel-switcher-item:hover { background:rgba(255,255,255,.06); }
            .channel-switcher-item.active { background:rgba(59,130,246,.15); color:var(--blue); }
            </style>
            <script>
            (function() {
                var btn  = document.getElementById('channelSwitcherBtn');
                var menu = document.getElementById('channelSwitcherMenu');
                if (!btn || !menu) return;
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    menu.classList.toggle('open');
                });
                document.addEventListener('click', function() { menu.classList.remove('open'); });
            })();
            </script>
            {% endif %}
            <a href="{{ path('profile_index') }}" class="btn-logout {{ app.request.attributes.get('_route') starts with 'profile' ? 'active' : '' }}" title="Profil &amp; Notifications">
                <i class="fas fa-user-cog"></i>
            </a>
            <a href="{{ path('auth_google') }}" class="btn-logout" title="Changer de chaîne YouTube">
                <i class="fab fa-youtube"></i>
            </a>
            <form method="post" action="{{ path('logout') }}" style="display:inline">
                <button type="submit" class="btn-logout" title="Déconnexion">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </form>
        </div>
        {% endif %}
    </div>
</nav>

<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                <i class="fas fa-{{ label == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
{% endblock %}

<script>
document.addEventListener('DOMContentLoaded', function() {

    // ── Nav hamburger ────────────────────────────────────────────────────────
    var navToggle = document.getElementById('navToggle');
    var navLinks  = document.getElementById('navLinks');
    if (navToggle) {
        navToggle.addEventListener('click', function() {
            var open = navLinks.classList.toggle('open');
            navToggle.querySelector('i').className = open ? 'fas fa-times' : 'fas fa-bars';
        });
    }

    // ── Toast notification ───────────────────────────────────────────────────
    window.showToast = function(message, type) {
        type = type || 'success';
        var icon = type === 'success' ? 'check-circle' : 'exclamation-circle';
        var el = document.createElement('div');
        el.className = 'alert alert-' + type;
        el.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;min-width:280px;max-width:420px';
        el.innerHTML = '<i class="fas fa-' + icon + '"></i> ' + message;
        document.body.appendChild(el);
        setTimeout(function() { if (el.parentNode) el.remove(); }, 4000);
    };

    // ── Sync button (/videos and other pages without overlay) ────────────────
    document.querySelectorAll('.js-sync-form').forEach(function(form) {
        if (document.getElementById('syncOverlay')) return; // dashboard overlay handles it
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var btn  = form.querySelector('button[type=submit]');
            var orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Synchronisation…';

            fetch(form.getAttribute('action'), {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false;
                btn.innerHTML = orig;
                window.showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) setTimeout(function() { window.location.reload(); }, 2500);
            })
            .catch(function() {
                btn.disabled = false;
                btn.innerHTML = orig;
                window.showToast('Erreur réseau', 'error');
            });
        });
    });

});
</script>
</body>
</html>
