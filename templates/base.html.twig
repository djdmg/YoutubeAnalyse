<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}YouTube Analyse{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body class="bg-dark">

<nav class="navbar">
    <div class="navbar-brand">
        <i class="fab fa-youtube" style="color:#ff0000"></i>
        <span>YouTube Analyse</span>
    </div>
    {% if app.user %}
    <button class="navbar-toggle" id="navToggle" aria-label="Menu">
        <i class="fas fa-bars"></i>
    </button>
    {% endif %}
    <div class="navbar-links" id="navLinks">
        {% if app.user %}
        <a href="{{ path('dashboard') }}" class="{{ app.request.attributes.get('_route') == 'dashboard' ? 'active' : '' }}">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>
        <a href="{{ path('videos') }}" class="{{ app.request.attributes.get('_route') == 'videos' ? 'active' : '' }}">
            <i class="fas fa-video"></i> Vidéos
        </a>
        <a href="{{ path('analytics_videos') }}" class="{{ app.request.attributes.get('_route') starts with 'analytics_video' ? 'active' : '' }}">
            <i class="fas fa-chart-bar"></i> Analytics
        </a>
        <a href="{{ path('analytics_alerts') }}" class="{{ app.request.attributes.get('_route') == 'analytics_alerts' ? 'active' : '' }}">
            <i class="fas fa-exclamation-triangle"></i> Alertes
        </a>
        <a href="{{ path('analytics_ai_costs') }}" class="{{ app.request.attributes.get('_route') == 'analytics_ai_costs' ? 'active' : '' }}">
            <i class="fas fa-robot"></i> Coûts IA
        </a>
        <a href="{{ path('playlists_create') }}" class="{{ app.request.attributes.get('_route') starts with 'playlists' ? 'active' : '' }}">
            <i class="fas fa-list-ul"></i> Playlists IA
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_users') }}" class="{{ app.request.attributes.get('_route') == 'admin_users' ? 'active' : '' }}" style="{{ app.request.attributes.get('_route') != 'admin_users' ? 'color:var(--yellow)' : '' }}">
            <i class="fas fa-users-cog"></i> Admin
            {% if pending_approval_count is defined and pending_approval_count > 0 %}
            <span class="nav-badge">{{ pending_approval_count }}</span>
            {% endif %}
        </a>
        <a href="{{ path('admin_settings') }}" class="{{ app.request.attributes.get('_route') == 'admin_settings' ? 'active' : '' }}" style="{{ app.request.attributes.get('_route') != 'admin_settings' ? 'color:var(--yellow)' : '' }}">
            <i class="fas fa-cogs"></i> Paramètres
        </a>
        {% endif %}
        <div class="navbar-user">
            {% if app.user.avatarUrl %}
            <img src="{{ app.user.avatarUrl }}" alt="{{ app.user.displayName }}" class="user-avatar">
            {% else %}
            <div class="user-avatar-placeholder"><i class="fas fa-user"></i></div>
            {% endif %}
            <span class="user-name">{{ app.user.displayName }}</span>
            <a href="{{ path('profile_index') }}" class="btn-logout {{ app.request.attributes.get('_route') starts with 'profile' ? 'active' : '' }}" title="Profil &amp; Notifications">
                <i class="fas fa-user-cog"></i>
            </a>
            <a href="{{ path('auth_google') }}" class="btn-logout" title="Changer de chaîne YouTube">
                <i class="fab fa-youtube"></i>
            </a>
            <form method="post" action="{{ path('logout') }}" style="display:inline">
                <button type="submit" class="btn-logout" title="Déconnexion">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </form>
        </div>
        {% endif %}
    </div>
</nav>
<script>
document.getElementById('navToggle')?.addEventListener('click', function() {
    const links = document.getElementById('navLinks');
    const isOpen = links.classList.toggle('open');
    this.querySelector('i').className = isOpen ? 'fas fa-times' : 'fas fa-bars';
});
</script>

<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                <i class="fas fa-{{ label == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
{% endblock %}

<script>
// ── Global AJAX utility ──────────────────────────────────────────────────────
window.ajaxPost = function(url, body, onSuccess, onError) {
    return fetch(url, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: body instanceof FormData ? body : new URLSearchParams(body),
    })
    .then(r => r.json().then(data => ({ ok: r.ok, data })))
    .then(({ ok, data }) => ok && data.success ? onSuccess(data) : (onError || showToast)(data.message || 'Erreur', 'error'))
    .catch(() => (onError || showToast)('Erreur réseau', 'error'));
};

window.showToast = function(message, type = 'success') {
    const el = document.createElement('div');
    el.className = 'alert alert-' + type;
    el.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;min-width:280px;max-width:420px;animation:fadeInRight .3s ease';
    el.innerHTML = '<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + '"></i> ' + message;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 4000);
};

// ── Sync button (dashboard + /videos) ───────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.js-sync-form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const btn = form.querySelector('button[type=submit]');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Synchronisation…';

            ajaxPost(form.action, new FormData(form),
                function(data) {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    showToast(data.message, 'success');
                },
                function(msg) {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    showToast(msg, 'error');
                }
            );
        });
    });
});
</script>
<style>
@keyframes fadeInRight { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:none; } }
</style>
</body>
</html>
