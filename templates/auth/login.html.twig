{% extends 'base.html.twig' %}

{% block title %}Connexion — YouTube Analyse{% endblock %}

{% block body %}
<div class="connect-card">
    <div class="connect-icon">
        <i class="fab fa-youtube"></i>
    </div>
    <h1>YouTube Analyse</h1>
    <p>Connecte-toi avec ton compte Google pour accéder à ton dashboard YouTube.</p>

    {% if error %}
    <div class="alert alert-error">
        <i class="fas fa-exclamation-circle"></i>
        {{ error.messageKey|trans(error.messageData, 'security') }}
    </div>
    {% endif %}

    <div class="feature-list">
        <div class="feature-item"><i class="fas fa-chart-bar"></i> Vues & Watch Time</div>
        <div class="feature-item"><i class="fas fa-users"></i> Évolution abonnés</div>
        <div class="feature-item"><i class="fas fa-euro-sign"></i> Revenus AdSense</div>
        <div class="feature-item"><i class="fas fa-trophy"></i> Top vidéos & CTR</div>
    </div>

    <a href="{{ path('auth_google') }}" class="btn-connect">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continuer avec Google
    </a>

    <p class="connect-note">
        <i class="fas fa-lock"></i>
        Tes données restent privées sur ta base de données.
    </p>
</div>
{% endblock %}
