{% extends 'base.html.twig' %}

{% block title %}Profil — YouTube Analyse{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1><i class="fas fa-user-cog"></i> Profil &amp; Notifications</h1>
        <span class="last-sync">{{ user.displayName }}</span>
    </div>
</div>

{% for type, messages in app.flashes %}
  {% for msg in messages %}
    <div class="alert-banner alert-{{ type == 'success' ? 'success' : 'danger' }}" style="margin-bottom:1.25rem">
        <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>
        <div>{{ msg }}</div>
    </div>
  {% endfor %}
{% endfor %}

<div class="section-card" style="max-width:680px">
    <div class="section-header">
        <h3><i class="fas fa-envelope"></i> Notifications par email</h3>
        {% if user.hasSmtpConfigured() %}
            <span class="badge badge-green" style="background:rgba(34,197,94,.15);color:#86efac;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600">
                <i class="fas fa-circle" style="font-size:8px;vertical-align:middle;margin-right:4px"></i> Actif
            </span>
        {% endif %}
    </div>

    <p style="color:var(--text-secondary);font-size:13px;margin:0 0 24px">
        Après chaque analyse IA, un email récapitulatif avec les recommandations est envoyé automatiquement.
    </p>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'profile-form'}}) }}

    {# ── Destination ───────────────────────────── #}
    <div class="form-section-title"><i class="fas fa-at"></i> Adresse de destination</div>

    <div class="form-field" style="margin-bottom:20px">
        {{ form_label(form.notifEmail, null, {'label_attr': {'class': ''}}) }}
        {{ form_widget(form.notifEmail, {'attr': {'class': 'form-control', 'placeholder': 'vous@exemple.com'}}) }}
        {% if form.notifEmail.vars.errors|length > 0 %}
            <span class="field-error">{{ form_errors(form.notifEmail) }}</span>
        {% endif %}
    </div>

    {# ── Serveur SMTP ──────────────────────────── #}
    <div class="form-section-title"><i class="fas fa-server"></i> Serveur SMTP</div>

    <div class="form-grid-2" style="margin-bottom:16px">
        <div class="form-field">
            {{ form_label(form.smtpHost) }}
            {{ form_widget(form.smtpHost, {'attr': {'class': 'form-control', 'placeholder': 'mail.exemple.com'}}) }}
        </div>
        <div class="form-field">
            {{ form_label(form.smtpPort) }}
            {{ form_widget(form.smtpPort, {'attr': {'class': 'form-control'}}) }}
        </div>
    </div>

    <div class="form-field" style="margin-bottom:20px">
        {{ form_label(form.smtpEncryption) }}
        {{ form_widget(form.smtpEncryption, {'attr': {'class': 'form-control'}}) }}
    </div>

    {# ── Authentification ──────────────────────── #}
    <div class="form-section-title"><i class="fas fa-key"></i> Authentification</div>

    <div class="form-grid-2" style="margin-bottom:24px">
        <div class="form-field">
            {{ form_label(form.smtpUser) }}
            {{ form_widget(form.smtpUser, {'attr': {'class': 'form-control', 'placeholder': 'user@exemple.com'}}) }}
        </div>
        <div class="form-field">
            {{ form_label(form.smtpPassword) }}
            {{ form_widget(form.smtpPassword, {'attr': {'class': 'form-control', 'autocomplete': 'new-password', 'placeholder': user.smtpPassword ? '••••••••' : 'Mot de passe'}}) }}
            <span class="help-text">Laisser vide pour conserver le mot de passe actuel.</span>
        </div>
    </div>

    {# ── Telegram ──────────────────────────────── #}
    <div class="form-section-title" style="margin-top:8px"><i class="fab fa-telegram"></i> Telegram</div>

    <div class="form-field" style="margin-bottom:8px">
        {{ form_label(form.telegramChatId) }}
        {{ form_widget(form.telegramChatId, {'attr': {'class': 'form-control'}}) }}
        <span class="help-text">
            Démarrez une conversation avec <strong>@userinfobot</strong> sur Telegram pour obtenir votre Chat ID.
            Le bot doit être configuré dans <code>TELEGRAM_BOT_TOKEN</code> côté serveur.
        </span>
    </div>

    {# ── Actions ───────────────────────────────── #}
    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-top:24px">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Enregistrer
        </button>
    </div>

    {{ form_end(form) }}

    {# Test email — form séparé pour éviter conflit avec le form de settings #}
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:12px">
        {% if user.hasSmtpConfigured() %}
        <form method="post" action="{{ path('profile_test_email') }}">
            <button type="submit" class="btn btn-outline">
                <i class="fas fa-paper-plane"></i> Test email
            </button>
        </form>
        {% endif %}

        <form method="post" action="{{ path('profile_test_telegram') }}" id="telegram-test-form">
            {# Pass current input value so Chat ID is saved even if user hasn't clicked Save yet #}
            <input type="hidden" name="telegram_chat_id" id="telegram-test-chat-id" value="{{ user.telegramChatId ?? '' }}">
            <button type="submit" class="btn btn-outline" style="border-color:#2ca5e0;color:#2ca5e0">
                <i class="fab fa-telegram"></i> Test Telegram
            </button>
        </form>
    </div>

    {# Statuts #}
    <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px">
        {% if user.hasSmtpConfigured() %}
        <div class="smtp-status active">
            <i class="fas fa-check-circle"></i>
            Email actif — <strong>{{ user.notifEmail }}</strong>
        </div>
        {% else %}
        <div class="smtp-status inactive">
            <i class="fas fa-info-circle"></i>
            Remplissez les champs SMTP pour activer les emails.
        </div>
        {% endif %}

        {% if user.hasTelegramConfigured() %}
        <div class="smtp-status active" style="border-color:#2ca5e0">
            <i class="fab fa-telegram" style="color:#2ca5e0"></i>
            Telegram actif — chat <strong>{{ user.telegramChatId }}</strong>
        </div>
        {% else %}
        <div class="smtp-status inactive">
            <i class="fab fa-telegram"></i>
            Entrez votre Chat ID pour activer Telegram.
        </div>
        {% endif %}
    </div>
</div>

<script>
// Keep the hidden test-form field in sync with the visible Chat ID input
(function () {
    var input  = document.querySelector('input[name="profile_email_settings[telegramChatId]"]');
    var hidden = document.getElementById('telegram-test-chat-id');
    if (input && hidden) {
        input.addEventListener('input', function () { hidden.value = this.value; });
    }
}());
</script>
{% endblock %}
