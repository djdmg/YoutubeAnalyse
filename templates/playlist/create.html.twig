{% extends 'base.html.twig' %}

{% block title %}Créer une playlist IA{% endblock %}

{% block body %}
<div class="page-header">
  <h1 class="page-title"><i class="fas fa-list-ul" style="color:var(--purple)"></i> Créer une playlist IA</h1>
  <p class="page-subtitle">L'IA analyse tes {{ video_count }} vidéos et propose des regroupements pertinents</p>
</div>

{# ── Step 1 : Formulaire ──────────────────────────────────────────── #}
<div id="step-form" class="playlist-card">
  <div class="playlist-card-header">
    <span class="step-badge"><i class="fas fa-magic" style="font-size:.8rem"></i></span>
    <span>Visibilité sur YouTube</span>
  </div>

  <div class="form-field" style="margin-bottom:24px">
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      {% for val, label in {'private': '🔒 Privée', 'unlisted': '🔗 Non répertoriée', 'public': '🌍 Publique'} %}
      <label class="privacy-option">
        <input type="radio" name="privacy" value="{{ val }}" {{ val == 'private' ? 'checked' : '' }}>
        <span>{{ label }}</span>
      </label>
      {% endfor %}
    </div>
  </div>

  <button id="btn-propose" class="btn btn-primary btn-lg">
    <i class="fas fa-magic"></i> Analyser mes vidéos et proposer des playlists
  </button>
</div>

{# ── Loading ──────────────────────────────────────────────────────── #}
<div id="step-loading" style="display:none" class="playlist-card" style="text-align:center;padding:48px">
  <div class="ai-loader">
    <div class="ai-loader-dot"></div>
    <div class="ai-loader-dot"></div>
    <div class="ai-loader-dot"></div>
  </div>
  <p style="color:var(--text-muted);margin-top:20px">L'IA analyse tes {{ video_count }} vidéos et prépare des propositions…</p>
</div>

{# ── Step 2 : Propositions ────────────────────────────────────────── #}
<div id="step-proposals" style="display:none">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px">
    <h2 style="margin:0;font-size:1.1rem">Propositions de l'IA — choisis et personnalise</h2>
    <button id="btn-back" class="btn btn-secondary btn-sm">
      <i class="fas fa-redo"></i> Regénérer
    </button>
  </div>
  <div id="proposals-container" style="display:flex;flex-direction:column;gap:24px"></div>
</div>

{# ── Success ──────────────────────────────────────────────────────── #}
<div id="step-success" style="display:none" class="playlist-card" style="text-align:center;padding:48px">
  <div style="font-size:3rem;margin-bottom:12px">🎉</div>
  <h2 style="margin:0 0 8px;color:var(--green)">Playlist créée !</h2>
  <p style="color:var(--text-muted);margin-bottom:24px" id="success-text"></p>
  <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
    <a id="success-link" href="#" target="_blank" class="btn btn-primary">
      <i class="fab fa-youtube"></i> Voir sur YouTube
    </a>
    <button onclick="resetAll()" class="btn btn-secondary">
      <i class="fas fa-plus"></i> Créer une autre playlist
    </button>
  </div>
</div>

{# ── Proposal card template ───────────────────────────────────────── #}
<template id="proposal-tpl">
  <div class="playlist-proposal">
    <div class="proposal-header">
      <div class="proposal-num"></div>
      <div style="flex:1">
        <input class="proposal-title" type="text" maxlength="100" placeholder="Titre de la playlist">
        <textarea class="proposal-desc" rows="2" maxlength="300" placeholder="Description"></textarea>
      </div>
      <div class="proposal-meta"></div>
    </div>
    <div class="proposal-videos"></div>
    <div class="proposal-footer">
      <span class="selected-count"></span>
      <button class="btn btn-create btn-primary">
        <i class="fab fa-youtube"></i> Créer cette playlist
      </button>
    </div>
  </div>
</template>

{# ── Video item template ───────────────────────────────────────────── #}
<template id="video-tpl">
  <label class="video-item">
    <input type="checkbox" checked>
    <img class="video-thumb" src="" alt="">
    <div class="video-info">
      <div class="video-title"></div>
      <div class="video-reason"></div>
    </div>
    <i class="fas fa-check video-check-icon"></i>
  </label>
</template>

<style>
.playlist-card { background:var(--card-bg); border-radius:12px; padding:24px; margin-bottom:20px; }
.playlist-card-header { display:flex; align-items:center; gap:12px; font-weight:600; font-size:1rem; margin-bottom:20px; color:var(--text); }
.step-badge { background:var(--purple); color:#fff; border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; flex-shrink:0; }
.form-label { display:block; font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; font-weight:600; }
.form-control { width:100%; background:#0f172a; border:1px solid #334155; border-radius:8px; color:var(--text); padding:10px 14px; font-size:0.9rem; box-sizing:border-box; resize:vertical; font-family:inherit; }
.form-control:focus { outline:none; border-color:var(--purple); }
.privacy-option { display:flex; align-items:center; gap:8px; background:#0f172a; border:1px solid #334155; border-radius:8px; padding:8px 16px; cursor:pointer; font-size:0.88rem; }
.privacy-option input { accent-color:var(--purple); }
.btn-lg { padding:12px 28px; font-size:1rem; }
.btn-sm { padding:6px 14px; font-size:0.82rem; }

/* Loader */
.ai-loader { display:flex; justify-content:center; gap:10px; padding:24px 0; }
.ai-loader-dot { width:12px; height:12px; border-radius:50%; background:var(--purple); animation:bounce 1.2s infinite ease-in-out; }
.ai-loader-dot:nth-child(2) { animation-delay:.2s; }
.ai-loader-dot:nth-child(3) { animation-delay:.4s; }
@keyframes bounce { 0%,80%,100%{transform:scale(.6);opacity:.4} 40%{transform:scale(1);opacity:1} }

/* Proposals */
.playlist-proposal { background:var(--card-bg); border-radius:12px; border:1px solid #1e293b; overflow:hidden; }
.proposal-header { padding:20px; display:flex; align-items:flex-start; gap:16px; background:#1e293b; }
.proposal-num { background:var(--purple); color:#fff; border-radius:50%; width:32px; height:32px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.9rem; flex-shrink:0; margin-top:4px; }
.proposal-title { width:100%; background:#0f172a; border:1px solid #334155; border-radius:8px; color:#fff; padding:8px 12px; font-size:1rem; font-weight:600; box-sizing:border-box; margin-bottom:8px; }
.proposal-desc { width:100%; background:#0f172a; border:1px solid #334155; border-radius:8px; color:var(--text-muted); padding:8px 12px; font-size:0.85rem; box-sizing:border-box; resize:vertical; font-family:inherit; }
.proposal-title:focus, .proposal-desc:focus { outline:none; border-color:var(--purple); }
.proposal-meta { font-size:0.78rem; color:var(--text-muted); white-space:nowrap; }

/* Video list */
.proposal-videos { padding:8px 16px; max-height:360px; overflow-y:auto; }
.video-item { display:flex; align-items:center; gap:12px; padding:8px 4px; cursor:pointer; border-bottom:1px solid #0f172a; transition:background .15s; border-radius:6px; }
.video-item:last-child { border-bottom:none; }
.video-item:hover { background:#1e293b; }
.video-item input[type=checkbox] { accent-color:var(--purple); width:16px; height:16px; flex-shrink:0; }
.video-thumb { width:72px; height:40px; border-radius:4px; object-fit:cover; background:#0f172a; flex-shrink:0; }
.video-info { flex:1; min-width:0; }
.video-title { font-size:0.85rem; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.video-reason { font-size:0.75rem; color:var(--purple); margin-top:2px; }
.video-check-icon { color:var(--green); font-size:0.8rem; flex-shrink:0; }
.video-item:has(input:not(:checked)) .video-check-icon { opacity:0; }
.video-item:has(input:not(:checked)) { opacity:.55; }

/* Footer */
.proposal-footer { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-top:1px solid #1e293b; }
.selected-count { font-size:0.85rem; color:var(--text-muted); }
.btn-create { padding:10px 24px; }
.btn-create:disabled { opacity:.5; cursor:not-allowed; }
</style>

<script>
const PROPOSE_URL = '{{ path('playlists_propose') }}';
const CONFIRM_URL = '{{ path('playlists_confirm') }}';

let currentPrivacy = 'private';

document.querySelectorAll('input[name=privacy]').forEach(r =>
  r.addEventListener('change', () => currentPrivacy = r.value)
);

document.getElementById('btn-propose').addEventListener('click', propose);
document.getElementById('btn-back').addEventListener('click', () => {
  show('step-form');
  hide('step-proposals');
});

async function propose() {
  show('step-loading'); hide('step-form'); hide('step-proposals'); hide('step-success');

  try {
    const res  = await fetch(PROPOSE_URL, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({prompt: ''}),
    });
    const data = await res.json();

    if (!res.ok || data.error) {
      alert(data.error || 'Erreur inattendue');
      show('step-form'); hide('step-loading');
      return;
    }

    renderProposals(data.proposals);
    hide('step-loading'); show('step-proposals');

  } catch (e) {
    alert('Erreur réseau : ' + e.message);
    show('step-form'); hide('step-loading');
  }
}

function renderProposals(proposals) {
  const container = document.getElementById('proposals-container');
  container.innerHTML = '';

  proposals.forEach((p, idx) => {
    const tpl   = document.getElementById('proposal-tpl').content.cloneNode(true);
    const el    = tpl.querySelector('.playlist-proposal');

    el.querySelector('.proposal-num').textContent   = idx + 1;
    el.querySelector('.proposal-title').value       = p.title;
    el.querySelector('.proposal-desc').value        = p.description;
    el.querySelector('.proposal-meta').textContent  = p.videos.length + ' vidéos';

    const videosEl = el.querySelector('.proposal-videos');
    p.videos.forEach(v => {
      const vtpl = document.getElementById('video-tpl').content.cloneNode(true);
      const vEl  = vtpl.querySelector('.video-item');
      const cb   = vEl.querySelector('input[type=checkbox]');

      vEl.querySelector('.video-thumb').src         = v.thumbnailUrl || '';
      vEl.querySelector('.video-title').textContent = v.title;
      vEl.querySelector('.video-reason').textContent = v.reason;
      cb.dataset.videoId = v.youtubeId;

      cb.addEventListener('change', () => updateCount(el));
      videosEl.appendChild(vEl);
    });

    updateCount(el);

    el.querySelector('.btn-create').addEventListener('click', () => confirmCreate(el));
    container.appendChild(el);
  });
}

function updateCount(proposalEl) {
  const total    = proposalEl.querySelectorAll('input[type=checkbox]').length;
  const checked  = proposalEl.querySelectorAll('input[type=checkbox]:checked').length;
  const btn      = proposalEl.querySelector('.btn-create');
  proposalEl.querySelector('.selected-count').textContent = checked + ' / ' + total + ' vidéos sélectionnées';
  btn.disabled = checked === 0;
}

async function confirmCreate(proposalEl) {
  const title       = proposalEl.querySelector('.proposal-title').value.trim();
  const description = proposalEl.querySelector('.proposal-desc').value.trim();
  const videoIds    = [...proposalEl.querySelectorAll('input[type=checkbox]:checked')].map(cb => cb.dataset.videoId);
  const btn         = proposalEl.querySelector('.btn-create');

  if (!title) { alert('Le titre est requis.'); return; }
  if (!videoIds.length) { alert('Sélectionne au moins une vidéo.'); return; }

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Création en cours…';

  try {
    const res  = await fetch(CONFIRM_URL, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({title, description, videoIds, privacy: currentPrivacy}),
    });
    const data = await res.json();

    if (!res.ok || data.error) {
      alert(data.error || 'Erreur inattendue');
      btn.disabled = false;
      btn.innerHTML = '<i class="fab fa-youtube"></i> Créer cette playlist';
      return;
    }

    document.getElementById('success-text').textContent =
      '"' + title + '" — ' + videoIds.length + ' vidéos ajoutées';
    document.getElementById('success-link').href = data.playlistUrl;
    hide('step-proposals'); show('step-success');

  } catch (e) {
    alert('Erreur réseau : ' + e.message);
    btn.disabled = false;
    btn.innerHTML = '<i class="fab fa-youtube"></i> Créer cette playlist';
  }
}

function resetAll() {
  hide('step-success'); hide('step-proposals'); hide('step-loading');
  show('step-form');
}

function show(id) { document.getElementById(id).style.display = ''; }
function hide(id) { document.getElementById(id).style.display = 'none'; }
</script>
{% endblock %}
