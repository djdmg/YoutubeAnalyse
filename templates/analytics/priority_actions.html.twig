{% extends 'base.html.twig' %}
{% block title %}Actions prioritaires — YouTube Analyse{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1><i class="fas fa-fire" style="color:#f59e0b"></i> Actions prioritaires</h1>
        <span class="last-sync">{{ total_alerts }} vidéo{{ total_alerts != 1 ? 's' : '' }} à optimiser sur {{ total_videos }}</span>
    </div>
    <div class="header-actions">
        <a href="{{ path('analytics_videos') }}" class="btn btn-outline btn-sm">
            <i class="fas fa-list"></i> Toutes les vidéos
        </a>
    </div>
</div>

{% if actions is empty %}
<div class="section-card">
    <div class="empty-state" style="padding:48px 24px;text-align:center">
        <i class="fas fa-check-circle fa-3x" style="color:var(--green);margin-bottom:16px"></i>
        <h3>Aucune action prioritaire</h3>
        <p style="color:var(--text-secondary)">Toutes vos vidéos sont correctement optimisées. Revenez après la prochaine synchronisation.</p>
    </div>
</div>
{% else %}

<div class="priority-legend section-card" style="margin-bottom:1.5rem;padding:1rem 1.5rem">
    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:center">
        <span style="font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;font-weight:600">Score d'urgence</span>
        <span class="priority-pill priority-high">≥ 60 — Critique</span>
        <span class="priority-pill priority-med">40–59 — Important</span>
        <span class="priority-pill priority-low">< 40 — À faire</span>
    </div>
</div>

<div style="display:flex;flex-direction:column;gap:1rem">
{% for action in actions %}
{% set score = action.score %}
{% set urgency = score >= 60 ? 'high' : (score >= 40 ? 'med' : 'low') %}
{% set urgencyColor = score >= 60 ? '#ef4444' : (score >= 40 ? '#f59e0b' : '#94a3b8') %}

<div class="section-card priority-card" style="border-left:3px solid {{ urgencyColor }}">
    <div class="priority-card-header">
        {# Thumbnail #}
        <div class="priority-thumb">
            {% if action.video.thumbnailUrl %}
            <a href="{{ path('analytics_video_detail', {youtubeId: action.video.youtubeId}) }}">
                <img src="{{ action.video.thumbnailUrl }}" alt="{{ action.video.title }}" loading="lazy">
            </a>
            {% else %}
            <div class="priority-thumb-placeholder"><i class="fas fa-video"></i></div>
            {% endif %}
        </div>

        {# Video info #}
        <div class="priority-video-info">
            <a href="{{ path('analytics_video_detail', {youtubeId: action.video.youtubeId}) }}" class="priority-video-title">
                {{ action.video.title|length > 70 ? action.video.title|slice(0,70) ~ '…' : action.video.title }}
            </a>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.35rem">
                {% if action.pub_days is not null %}
                <span class="stat-chip"><i class="fas fa-calendar-alt"></i> {{ action.pub_days }}j</span>
                {% endif %}
                {% if action.stats.avg_ctr is not null %}
                <span class="stat-chip"><i class="fas fa-mouse-pointer"></i> CTR {{ action.stats.avg_ctr|number_format(2) }}%</span>
                {% endif %}
                {% if action.stats.total_impressions > 0 %}
                <span class="stat-chip"><i class="fas fa-eye"></i> {{ action.stats.total_impressions|number_format(0, ',', ' ') }} imp.</span>
                {% endif %}
                {% if action.stats.avg_retention is not null %}
                <span class="stat-chip"><i class="fas fa-chart-area"></i> {{ action.stats.avg_retention|number_format(1) }}% rét.</span>
                {% endif %}
            </div>
        </div>

        {# Score badge #}
        <div class="priority-score" style="background:{{ urgencyColor }}18;border:1px solid {{ urgencyColor }}40">
            <div class="priority-score-num" style="color:{{ urgencyColor }}">{{ score }}</div>
            <div class="priority-score-label">score</div>
        </div>
    </div>

    {# Action items #}
    <div class="priority-items">
        {% for item in action.items %}
        <div class="priority-item">
            <div class="priority-item-icon" style="background:{{ item.color }}18;color:{{ item.color }}">
                <i class="fas {{ item.icon }}"></i>
            </div>
            <div class="priority-item-content">
                <div class="priority-item-label">{{ item.label }}</div>
                <div class="priority-item-action"><i class="fas fa-arrow-right" style="font-size:.7em;opacity:.6"></i> {{ item.action }}</div>
            </div>
            <div class="priority-item-pts" style="color:{{ item.color }}">+{{ item.pts }}</div>
        </div>
        {% endfor %}
    </div>

    {# Quick action links #}
    <div class="priority-card-footer">
        <a href="{{ path('analytics_video_detail', {youtubeId: action.video.youtubeId}) }}" class="btn btn-outline btn-xs">
            <i class="fas fa-chart-bar"></i> Analytics
        </a>
        <a href="{{ path('analytics_video_detail', {youtubeId: action.video.youtubeId}) }}#thumbnail" class="btn btn-outline btn-xs">
            <i class="fas fa-image"></i> Miniature
        </a>
        <a href="https://studio.youtube.com/video/{{ action.video.youtubeId }}/edit" target="_blank" rel="noopener" class="btn btn-outline btn-xs">
            <i class="fab fa-youtube"></i> YouTube Studio
        </a>
    </div>
</div>
{% endfor %}
</div>
{% endif %}

<style>
.priority-card { transition: transform .15s; }
.priority-card:hover { transform: translateY(-1px); }
.priority-card-header { display:flex; align-items:flex-start; gap:1rem; }
.priority-thumb { width:120px; flex-shrink:0; }
.priority-thumb img { width:120px; height:68px; object-fit:cover; border-radius:6px; }
.priority-thumb-placeholder { width:120px; height:68px; border-radius:6px; background:var(--bg-tertiary); display:flex; align-items:center; justify-content:center; color:var(--text-muted); }
.priority-video-info { flex:1; min-width:0; }
.priority-video-title { font-weight:600; color:var(--text-primary); text-decoration:none; font-size:.95rem; line-height:1.4; }
.priority-video-title:hover { color:var(--blue); }
.stat-chip { display:inline-flex; align-items:center; gap:.3rem; font-size:.75rem; color:var(--text-muted); background:var(--bg-tertiary); padding:.2rem .5rem; border-radius:4px; }
.priority-score { display:flex; flex-direction:column; align-items:center; justify-content:center; width:64px; height:64px; border-radius:12px; flex-shrink:0; }
.priority-score-num { font-size:1.4rem; font-weight:700; line-height:1; }
.priority-score-label { font-size:.65rem; text-transform:uppercase; letter-spacing:.06em; opacity:.7; }
.priority-items { margin-top:1rem; display:flex; flex-direction:column; gap:.5rem; border-top:1px solid var(--border); padding-top:.875rem; }
.priority-item { display:flex; align-items:center; gap:.75rem; }
.priority-item-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.8rem; flex-shrink:0; }
.priority-item-content { flex:1; min-width:0; }
.priority-item-label { font-size:.85rem; font-weight:500; color:var(--text-primary); }
.priority-item-action { font-size:.78rem; color:var(--text-muted); margin-top:.1rem; }
.priority-item-pts { font-size:.85rem; font-weight:700; flex-shrink:0; }
.priority-card-footer { display:flex; gap:.5rem; margin-top:.875rem; padding-top:.875rem; border-top:1px solid var(--border); flex-wrap:wrap; }
.btn-xs { padding:.25rem .6rem; font-size:.75rem; }
.priority-pill { font-size:.75rem; padding:.2rem .6rem; border-radius:999px; font-weight:600; }
.priority-pill.priority-high { background:#ef444418; color:#ef4444; border:1px solid #ef444430; }
.priority-pill.priority-med  { background:#f59e0b18; color:#f59e0b; border:1px solid #f59e0b30; }
.priority-pill.priority-low  { background:rgba(148,163,184,.12); color:#94a3b8; border:1px solid rgba(148,163,184,.25); }
</style>
{% endblock %}
