{% extends 'base.html.twig' %}

{% block title %}{{ video.title }} — Détail{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1>
            {% if video.thumbnailUrl %}
            <img src="{{ video.thumbnailUrl }}" alt="" class="video-thumb-header" id="headerThumbnail">
            {% endif %}
            {{ video.title|length > 60 ? video.title|slice(0,60) ~ '…' : video.title }}
        </h1>
        {% if video.publishedAt %}
        <span class="last-sync"><i class="fas fa-calendar"></i> {{ video.publishedAt|date('d/m/Y H:i') }}</span>
        {% endif %}
    </div>
    <div class="header-actions">
        <a href="{{ path('analytics_videos') }}" class="btn btn-outline">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
        <a href="{{ path('analytics_video_export', {youtubeId: video.youtubeId}) }}" class="btn btn-outline">
            <i class="fas fa-download"></i> CSV
        </a>
        <button class="btn btn-outline" onclick="window.print()" title="Imprimer / Enregistrer en PDF">
            <i class="fas fa-print"></i> PDF
        </button>
        <a href="https://youtube.com/watch?v={{ video.youtubeId }}" target="_blank" class="btn btn-outline">
            <i class="fab fa-youtube"></i> Voir sur YouTube
        </a>
    </div>
</div>

{# ── Tab nav ──────────────────────────────────────────────────────────── #}
{% set ai_count = (prediction ? 1 : 0) + (title_report ? 1 : 0) + (comment_report ? 1 : 0) + (description_report ? 1 : 0) %}
{% set opti_count = (seo_report ? 1 : 0) + (title_report ? 1 : 0) + (meta_history|length > 1 ? 1 : 0) %}

<div class="tab-nav" id="detailTabs">
    <button class="tab-btn active" data-tab="perf" onclick="switchTab('perf')">
        <i class="fas fa-chart-line"></i> Performance
    </button>
    <button class="tab-btn" data-tab="ai" onclick="switchTab('ai')">
        <i class="fas fa-robot"></i> Analyses IA
        {% if ai_count > 0 %}<span class="tab-badge">{{ ai_count }}</span>{% endif %}
    </button>
    <button class="tab-btn" data-tab="opti" onclick="switchTab('opti')">
        <i class="fas fa-magic"></i> Optimisations
        {% if opti_count > 0 %}<span class="tab-badge">{{ opti_count }}</span>{% endif %}
    </button>
</div>

<script>
var _activeTab = (function() {
    try { return localStorage.getItem('yt_tab_{{ video.youtubeId }}') || 'perf'; } catch(e) { return 'perf'; }
})();

function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.toggle('active', b.getAttribute('data-tab') === name);
    });
    document.querySelectorAll('.tab-panel').forEach(function(p) {
        p.style.display = p.id === 'tab-' + name ? 'block' : 'none';
    });
    try { localStorage.setItem('yt_tab_{{ video.youtubeId }}', name); } catch(e) {}
    _activeTab = name;
}
switchTab(_activeTab);
</script>

{# ══════════════════════════════════════════════════════════════════════ #}
{# Tab 1 — Performance                                                    #}
{# ══════════════════════════════════════════════════════════════════════ #}
<div class="tab-panel active" id="tab-perf">

    {# KPI Cards #}
    {% if latest_metric %}
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon views"><i class="fas fa-eye"></i></div>
            <div class="kpi-content">
                <div class="kpi-value">{{ latest_metric.views|number_format(0, ',', ' ') }}</div>
                <div class="kpi-label">Vues (J)</div>
            </div>
        </div>
        {% if latest_metric.ctr is not null %}
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(234,179,8,0.15);color:#eab308"><i class="fas fa-percentage"></i></div>
            <div class="kpi-content">
                <div class="kpi-value">{{ latest_metric.ctr|number_format(2) }}%</div>
                <div class="kpi-label">CTR</div>
            </div>
        </div>
        {% endif %}
        {% if latest_metric.watchTimeMinutes %}
        <div class="kpi-card">
            <div class="kpi-icon watchtime"><i class="fas fa-clock"></i></div>
            <div class="kpi-content">
                <div class="kpi-value">{{ (latest_metric.watchTimeMinutes / 60)|number_format(1, ',', ' ') }}h</div>
                <div class="kpi-label">Watch Time</div>
            </div>
        </div>
        {% endif %}
        {% if latest_metric.avgRetentionPercent is not null %}
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(168,85,247,0.15);color:#a855f7"><i class="fas fa-film"></i></div>
            <div class="kpi-content">
                <div class="kpi-value">{{ latest_metric.avgRetentionPercent|number_format(1) }}%</div>
                <div class="kpi-label">Rétention moy.</div>
            </div>
        </div>
        {% endif %}
        {% if latest_metric.subscribersGained is not null %}
        <div class="kpi-card">
            <div class="kpi-icon subscribers"><i class="fas fa-user-plus"></i></div>
            <div class="kpi-content">
                <div class="kpi-value">+{{ latest_metric.subscribersGained }}</div>
                <div class="kpi-label">Abonnés gagnés</div>
            </div>
        </div>
        {% endif %}
        {% if estimated_revenue is defined and estimated_revenue > 0 %}
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(34,197,94,0.15);color:var(--green)"><i class="fas fa-euro-sign"></i></div>
            <div class="kpi-content">
                <div class="kpi-value">{{ estimated_revenue|number_format(2, ',', ' ') }} €</div>
                <div class="kpi-label">Revenu estimé (30j, {{ estimated_rpm }} €/k)</div>
            </div>
        </div>
        {% endif %}
        {% if thumbnail_report is defined and thumbnail_report and thumbnail_report.payload %}
        {% set thumb_score = thumbnail_report.payload.score ?? 0 %}
        {% set thumb_color = thumb_score >= 7 ? 'var(--green)' : (thumb_score >= 5 ? 'var(--yellow)' : '#ef4444') %}
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(168,85,247,0.15);color:#a855f7"><i class="fas fa-image"></i></div>
            <div class="kpi-content">
                <div class="kpi-value" style="color:{{ thumb_color }}">{{ thumb_score }}/10</div>
                <div class="kpi-label">Score miniature</div>
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Anomaly Banner #}
    {% if anomaly_report and anomaly_report.payload %}
    <div class="alert-banner alert-{{ anomaly_report.payload.type == 'surperformance' ? 'success' : 'danger' }}">
        <i class="fas fa-{{ anomaly_report.payload.type == 'surperformance' ? 'rocket' : 'exclamation-triangle' }}"></i>
        <div>
            <strong>{{ anomaly_report.payload.type == 'surperformance' ? 'Surperformance détectée !' : 'Sous-performance détectée' }}</strong>
            <p>{{ anomaly_report.payload.cause_probable }}</p>
            <p class="alert-action"><i class="fas fa-lightbulb"></i> {{ anomaly_report.payload.action_recommandee }}</p>
        </div>
    </div>
    {% endif %}

    {# Charts #}
    <div class="detail-grid">
        {% if chart_data.labels|length > 0 %}
        <div class="chart-card span-2">
            <div class="chart-header"><h3><i class="fas fa-eye"></i> Vues journalières</h3></div>
            <canvas id="viewsChart" height="80"></canvas>
        </div>
        {% endif %}
        {% if retention_data.labels|length > 0 %}
        <div class="chart-card">
            <div class="chart-header"><h3><i class="fas fa-film"></i> Courbe de rétention</h3></div>
            <canvas id="retentionChart" height="120"></canvas>
        </div>
        {% endif %}
        {% if chart_data.ctr|filter(v => v > 0)|length > 0 %}
        <div class="chart-card">
            <div class="chart-header"><h3><i class="fas fa-percentage"></i> CTR</h3></div>
            <canvas id="ctrChart" height="120"></canvas>
        </div>
        {% endif %}
    </div>

    {# Traffic Sources (30j) + Search Terms #}
    <div class="detail-grid" style="grid-template-columns: 1fr 1fr">
        {% if traffic_sources_agg is defined and traffic_sources_agg|length > 0 %}
        <div class="section-card">
            <div class="section-header">
                <h3><i class="fas fa-traffic-light"></i> Sources de trafic <small style="font-size:11px;font-weight:400;color:var(--text-muted)">(30 derniers jours)</small></h3>
            </div>
            <div class="traffic-sources">
                {% set total = traffic_total %}
                {% for source, views in traffic_sources_agg %}
                {% set label = traffic_source_labels[source] ?? source|replace({'_': ' '}) %}
                <div class="traffic-row">
                    <span class="traffic-source">{{ label }}</span>
                    <div style="display:flex;align-items:center;gap:8px">
                        {% if total > 0 %}
                        <div class="traffic-bar-wrap">
                            <div class="traffic-bar" style="width:{{ ((views / total) * 100)|round }}%"></div>
                        </div>
                        <span style="font-size:11px;color:var(--text-muted);width:32px;text-align:right">{{ ((views / total) * 100)|round }}%</span>
                        {% endif %}
                        <span class="traffic-views">{{ views|number_format(0, ',', ' ') }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% elseif latest_metric and latest_metric.trafficSources %}
        <div class="section-card">
            <div class="section-header"><h3><i class="fas fa-traffic-light"></i> Sources de trafic</h3></div>
            <div class="traffic-sources">
                {% set total = latest_metric.trafficSources|reduce((carry, v) => carry + v, 0) %}
                {% for source, views in latest_metric.trafficSources %}
                <div class="traffic-row">
                    <span class="traffic-source">{{ source|replace({'_': ' '}) }}</span>
                    <div style="display:flex;align-items:center;gap:8px">
                        {% if total > 0 %}
                        <div class="traffic-bar-wrap">
                            <div class="traffic-bar" style="width:{{ ((views / total) * 100)|round }}%"></div>
                        </div>
                        <span style="font-size:11px;color:var(--text-muted);width:32px;text-align:right">{{ ((views / total) * 100)|round }}%</span>
                        {% endif %}
                        <span class="traffic-views">{{ views|number_format(0, ',', ' ') }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {% if search_terms|length > 0 %}
        <div class="section-card">
            <div class="section-header">
                <h3><i class="fas fa-search"></i> Requêtes de recherche</h3>
                <span style="font-size:12px;color:var(--text-muted)">{{ search_terms|length }} requêtes</span>
            </div>
            {% set maxViews = search_terms[0].views %}
            <div class="traffic-sources">
                {% for term in search_terms %}
                <div class="traffic-row">
                    <span class="traffic-source" style="font-size:13px;max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ term.query }}">
                        {{ term.query }}
                    </span>
                    <div style="display:flex;align-items:center;gap:8px">
                        {% if maxViews > 0 %}
                        <div class="traffic-bar-wrap">
                            <div class="traffic-bar" style="width:{{ ((term.views / maxViews) * 100)|round }}%;background:var(--purple)"></div>
                        </div>
                        {% endif %}
                        <span class="traffic-views">{{ term.views }} vues</span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% else %}
        <div class="section-card">
            <div class="section-header"><h3><i class="fas fa-search"></i> Requêtes de recherche</h3></div>
            <div class="empty-state" style="padding:24px">
                <i class="fas fa-sync fa-lg"></i>
                <p style="margin-top:8px;font-size:13px">Données disponibles après la prochaine synchronisation</p>
            </div>
        </div>
        {% endif %}
    </div>

</div>{# /tab-perf #}

{# ══════════════════════════════════════════════════════════════════════ #}
{# Tab 2 — Analyses IA                                                    #}
{# ══════════════════════════════════════════════════════════════════════ #}
<div class="tab-panel" id="tab-ai">

    {% if ai_count == 0 %}
    <div class="section-card">
        <div class="empty-state">
            <i class="fas fa-robot fa-3x"></i>
            <h3>Aucune analyse IA</h3>
            <p>Lancez l'analyse complète pour générer prédictions, anomalies et commentaires.</p>
            <button class="btn btn-primary" style="margin-top:1rem" onclick="triggerAnalysis()">
                <i class="fas fa-play"></i> Lancer l'analyse complète
            </button>
            <div id="aiAnalysisStatus" style="margin-top:.75rem;font-size:.85em;color:var(--text-muted);display:none"></div>
        </div>
    </div>
    {% else %}
    <div class="ai-blocks-grid">

        {# Projection J+30 #}
        {% if prediction and prediction.payload %}
        <div class="ai-block ai-block-prediction">
            <div class="ai-block-header">
                <i class="fas fa-chart-line"></i>
                <h3>Projection J+30</h3>
                <span class="ai-model">{{ prediction.modelVersion }}</span>
            </div>
            <div class="prediction-main">
                <div class="prediction-value">{{ prediction.payload.vues_estimees_j30|number_format(0, ',', ' ') }}</div>
                <div class="prediction-label">vues estimées</div>
                <div class="prediction-range">
                    {{ prediction.payload.fourchette.min|number_format(0, ',', ' ') }} – {{ prediction.payload.fourchette.max|number_format(0, ',', ' ') }} vues
                </div>
            </div>
            <div class="confidence-gauge confidence-{{ prediction.payload.confiance }}">
                <span>Confiance : <strong>{{ prediction.payload.confiance }}</strong></span>
            </div>
            {% if prediction.payload.facteurs %}
            <ul class="ai-list">
                {% for f in prediction.payload.facteurs %}<li>{{ f }}</li>{% endfor %}
            </ul>
            {% endif %}
        </div>
        {% endif %}

        {# Anomaly details #}
        {% if anomaly_report and anomaly_report.payload %}
        <div class="ai-block" style="border-color:{{ anomaly_report.payload.type == 'surperformance' ? 'rgba(34,197,94,.3)' : 'rgba(239,68,68,.3)' }}">
            <div class="ai-block-header">
                <i class="fas fa-{{ anomaly_report.payload.type == 'surperformance' ? 'rocket' : 'exclamation-triangle' }}" style="color:{{ anomaly_report.payload.type == 'surperformance' ? 'var(--green)' : '#ef4444' }}"></i>
                <h3>Détection d'anomalie</h3>
                <span class="ai-model">{{ anomaly_report.modelVersion }}</span>
            </div>
            <p style="color:var(--text-secondary);font-size:13px;margin-bottom:8px"><strong>Cause :</strong> {{ anomaly_report.payload.cause_probable }}</p>
            <p style="color:var(--text-secondary);font-size:13px;font-style:italic"><i class="fas fa-lightbulb" style="color:var(--yellow)"></i> {{ anomaly_report.payload.action_recommandee }}</p>
        </div>
        {% endif %}

        {# Feedback audience #}
        {% if comment_report and comment_report.payload %}
        <div class="ai-block ai-block-comments">
            <div class="ai-block-header">
                <i class="fas fa-comments"></i>
                <h3>Feedback audience</h3>
                <span class="ai-model">{{ comment_report.modelVersion }}</span>
            </div>
            {% set score = comment_report.payload.score_sentiment ?? 0 %}
            {% set sg = comment_report.payload.sentiment_global ?? 'neutre' %}
            <div class="sentiment-widget">
                <div class="sentiment-score sentiment-{{ sg }}">
                    <span class="sentiment-emoji">{{ sg == 'positif' ? '😊' : (sg == 'négatif' ? '😞' : '😐') }}</span>
                    <span class="sentiment-label">{{ sg|capitalize }}</span>
                    <span class="sentiment-pct">{{ (score * 100)|round }}%</span>
                </div>
            </div>
            <p class="ai-resume">{{ comment_report.payload.resume }}</p>
            {% if comment_report.payload.themes_recurrents %}
            <div class="themes-list">
                {% for t in comment_report.payload.themes_recurrents %}
                <span class="theme-tag">{{ t }}</span>
                {% endfor %}
            </div>
            {% endif %}
            {% if comment_report.payload.demandes_tracklist %}
            <div class="tracklist-notice"><i class="fas fa-music"></i> Tracklist demandée en commentaires</div>
            {% endif %}
        </div>
        {% endif %}

        {# Thumbnail Analysis #}
        {% if thumbnail_report is defined and thumbnail_report and thumbnail_report.payload %}
        {% set tp = thumbnail_report.payload %}
        {% set ts = tp.score ?? 0 %}
        {% set tc = ts >= 7 ? 'var(--green)' : (ts >= 5 ? 'var(--yellow)' : '#ef4444') %}
        <div class="ai-block">
            <div class="ai-block-header">
                <i class="fas fa-image" style="color:#a855f7"></i>
                <h3>Analyse miniature</h3>
                <span class="ai-model">{{ thumbnail_report.modelVersion }}</span>
            </div>
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:12px">
                {% if video.thumbnailUrl %}
                <img src="{{ video.thumbnailUrl }}" alt="" style="width:80px;border-radius:6px;flex-shrink:0">
                {% endif %}
                <div>
                    <div style="font-size:28px;font-weight:700;color:{{ tc }}">{{ ts }}/10</div>
                    <div style="font-size:12px;color:var(--text-muted)">Score de la miniature</div>
                </div>
            </div>
            {% if tp.force is defined and tp.force|length > 0 %}
            <div style="margin-bottom:8px">
                <div style="font-size:11px;color:var(--green);font-weight:600;margin-bottom:4px"><i class="fas fa-check-circle"></i> Points forts</div>
                {% for f in tp.force %}
                <div style="font-size:13px;color:var(--text-secondary);padding:2px 0">• {{ f }}</div>
                {% endfor %}
            </div>
            {% endif %}
            {% if tp.faiblesse is defined and tp.faiblesse|length > 0 %}
            <div style="margin-bottom:10px">
                <div style="font-size:11px;color:var(--yellow);font-weight:600;margin-bottom:4px"><i class="fas fa-exclamation-triangle"></i> Points faibles</div>
                {% for f in tp.faiblesse %}
                <div style="font-size:13px;color:var(--text-secondary);padding:2px 0">• {{ f }}</div>
                {% endfor %}
            </div>
            {% endif %}
            {% if tp.recommandation is defined %}
            <div style="background:rgba(168,85,247,.08);border-left:3px solid #a855f7;border-radius:0 6px 6px 0;padding:10px 12px;font-size:13px;color:var(--text-secondary)">
                <i class="fas fa-lightbulb" style="color:var(--yellow);margin-right:6px"></i>{{ tp.recommandation }}
            </div>
            {% endif %}
        </div>
        {% endif %}

        {# Description Optimization #}
        {% if description_report is defined and description_report and description_report.payload %}
        {% set dp = description_report.payload %}
        <div class="ai-block">
            <div class="ai-block-header">
                <i class="fas fa-file-alt" style="color:var(--blue)"></i>
                <h3>Description optimisée</h3>
                <span class="ai-model">{{ description_report.modelVersion }}</span>
            </div>
            {% if dp.description_optimisee is defined %}
            <div id="descOptText" style="background:var(--bg-secondary);border-radius:6px;padding:12px 14px;font-size:13px;color:var(--text-secondary);line-height:1.6;white-space:pre-line;margin-bottom:10px;max-height:200px;overflow-y:auto">{{ dp.description_optimisee }}</div>
            <button type="button" class="btn btn-outline btn-sm" onclick="(function(){var t=document.getElementById('descOptText');if(navigator.clipboard){navigator.clipboard.writeText(t.innerText);}else{var r=document.createRange();r.selectNode(t);window.getSelection().removeAllRanges();window.getSelection().addRange(r);document.execCommand('copy');window.getSelection().removeAllRanges();}var btn=event.currentTarget;var orig=btn.innerHTML;btn.innerHTML='<i class=\"fas fa-check\"></i> Copié !';setTimeout(function(){btn.innerHTML=orig;},2000);})()">
                <i class="fas fa-copy"></i> Copier
            </button>
            {% endif %}
            {% if dp.mots_cles_integres is defined and dp.mots_cles_integres|length > 0 %}
            <div class="ai-keywords" style="margin-top:12px">
                {% for kw in dp.mots_cles_integres %}
                <span class="keyword-tag"><i class="fas fa-key" style="font-size:9px;margin-right:3px"></i>{{ kw }}</span>
                {% endfor %}
            </div>
            {% endif %}
            {% if dp.ameliorations is defined and dp.ameliorations|length > 0 %}
            <ul class="ai-list" style="margin-top:10px">
                {% for a in dp.ameliorations %}<li>{{ a }}</li>{% endfor %}
            </ul>
            {% endif %}
        </div>
        {% endif %}

    </div>
    {% endif %}

</div>{# /tab-ai #}

{# ══════════════════════════════════════════════════════════════════════ #}
{# Tab 3 — Optimisations                                                  #}
{# ══════════════════════════════════════════════════════════════════════ #}
<div class="tab-panel" id="tab-opti">

    {% if opti_count == 0 %}
    <div class="section-card">
        <div class="empty-state">
            <i class="fas fa-magic fa-3x"></i>
            <h3>Aucune suggestion d'optimisation</h3>
            <p>Lancez l'analyse pour obtenir des recommandations SEO et titre.</p>
            <button class="btn btn-primary" style="margin-top:1rem" onclick="triggerAnalysis()">
                <i class="fas fa-play"></i> Lancer l'analyse complète
            </button>
            <div id="aiAnalysisStatusOpti" style="margin-top:.75rem;font-size:.85em;color:var(--text-muted);display:none"></div>
        </div>
    </div>
    {% endif %}

    {# Title recommendations #}
    {% if title_report and title_report.payload %}
    <div class="ai-block ai-block-title" style="margin-bottom:20px">
        <div class="ai-block-header">
            <i class="fas fa-magic"></i>
            <h3>Recommandations de titre — IA</h3>
            <span class="ai-model">{{ title_report.modelVersion }}</span>
        </div>
        <p class="ai-diagnostic"><i class="fas fa-search"></i> {{ title_report.payload.diagnostic }}</p>
        <div class="ai-suggestions">
            <strong>Titres suggérés :</strong>
            {% for t in title_report.payload.suggestions_titres ?? [] %}
            <div class="suggestion-item">{{ t }}</div>
            {% endfor %}
        </div>
        {% if title_report.payload.mots_cles_manquants %}
        <div class="ai-keywords">
            {% for kw in title_report.payload.mots_cles_manquants %}
            <span class="keyword-tag">{{ kw }}</span>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# SEO Report #}
    {% if seo_report and seo_report.payload %}
    {% set p = seo_report.payload %}
    <div class="section-card" style="border-left:3px solid var(--purple);margin-bottom:20px">
        <div class="section-header">
            <h3><i class="fas fa-magic" style="color:var(--purple)"></i> Suggestions SEO — IA</h3>
            <span class="ai-model">{{ seo_report.modelVersion }}</span>
        </div>
        <div style="background:rgba(168,85,247,.08);border-radius:6px;padding:8px 12px;margin-bottom:16px;font-size:12px;color:var(--text-muted)">
            <i class="fas fa-info-circle" style="color:var(--purple)"></i>
            Suggestions uniquement — aucune modification n'est appliquée automatiquement sur ta chaîne.
        </div>
        {% if p.diagnostic is defined %}
        <div class="ai-diagnostic" style="margin-bottom:16px">{{ p.diagnostic }}</div>
        {% endif %}
        {% if p.titre_optimise is defined %}
        <div class="field-label">Titre optimisé</div>
        <div style="background:var(--bg-secondary);border-left:3px solid var(--blue);border-radius:0 6px 6px 0;padding:10px 14px;font-size:14px;font-weight:500;color:#e2e8f0;margin-bottom:16px">
            {{ p.titre_optimise }}
        </div>
        {% endif %}
        {% if p.mots_cles_manquants is defined and p.mots_cles_manquants|length > 0 %}
        <div class="field-label">Mots-clés manquants</div>
        <div class="ai-keywords" style="margin-bottom:16px">
            {% for kw in p.mots_cles_manquants %}
            <span class="keyword-tag"><i class="fas fa-plus" style="font-size:9px;margin-right:3px"></i>{{ kw }}</span>
            {% endfor %}
        </div>
        {% endif %}
        {% if p.description_optimisee is defined %}
        <div class="field-label">Description optimisée</div>
        <div style="background:var(--bg-secondary);border-radius:6px;padding:12px 14px;font-size:13px;color:var(--text-secondary);line-height:1.6;white-space:pre-line;margin-bottom:4px">{{ p.description_optimisee }}</div>
        {% endif %}
        {% if p.requetes_principales is defined and p.requetes_principales|length > 0 %}
        <div style="margin-top:12px;font-size:12px;color:var(--text-muted)">
            <i class="fas fa-search"></i> Requêtes ciblées : {{ p.requetes_principales|join(', ') }}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Imagen Thumbnail Generation #}
    <div class="section-card" style="border-left:3px solid #f59e0b;margin-bottom:20px">
        <div class="section-header">
            <h3><i class="fas fa-image" style="color:#f59e0b"></i> Générer une miniature — {{ thumbnail_model_name }}</h3>
            <span style="font-size:11px;background:rgba(245,158,11,.15);color:#f59e0b;padding:2px 8px;border-radius:12px">{{ thumbnail_model_name }}</span>
        </div>
        <div style="background:rgba(245,158,11,.08);border-radius:6px;padding:8px 12px;margin-bottom:16px;font-size:12px;color:var(--text-muted)">
            <i class="fas fa-info-circle" style="color:#f59e0b"></i>
            Générez une miniature IA, prévisualisez-la, puis appliquez-la si elle vous convient.
        </div>

        {# Comparison: current vs generated #}
        <div style="display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap">
            <div style="flex:1;min-width:200px">
                <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em">Miniature actuelle</div>
                {% if video.thumbnailUrl %}
                <img src="{{ video.thumbnailUrl }}" alt="Miniature actuelle" style="width:100%;border-radius:8px;display:block">
                {% else %}
                <div style="width:100%;aspect-ratio:16/9;background:var(--bg-secondary);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:13px">Aucune miniature</div>
                {% endif %}
            </div>
            <div style="flex:1;min-width:200px" id="imagenPreviewCol" style="display:none">
                <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em">Miniature générée</div>
                <img id="imagenPreviewImg" src="" alt="Miniature générée" style="width:100%;border-radius:8px;display:none">
                <div id="imagenPreviewPlaceholder" style="width:100%;aspect-ratio:16/9;background:var(--bg-secondary);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:13px">
                    <span><i class="fas fa-wand-magic-sparkles" style="margin-right:6px;color:#f59e0b"></i>Aperçu ici</span>
                </div>
            </div>
        </div>

        {# Prompt + controls #}
        <div style="display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap">
            <textarea id="imagenPrompt" rows="3"
                   placeholder="Décrivez la miniature souhaitée, ou cliquez sur « Suggérer » pour en générer une automatiquement…"
                   style="flex:1;min-width:200px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text-primary);font-size:13px;outline:none;resize:vertical;line-height:1.5"></textarea>
        </div>
        {# Meta-prompt viewer — hidden until a suggestion is generated #}
        <div id="metaPromptDetails" style="display:none;margin-bottom:12px;background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.2);border-radius:10px;overflow:hidden">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:.6rem .875rem;border-bottom:1px solid rgba(99,102,241,.15);cursor:pointer;user-select:none" onclick="var p=document.getElementById('metaPromptBody');p.style.display=p.style.display==='none'?'':'none'">
                <span style="font-size:.75rem;font-weight:600;color:#a78bfa;display:flex;align-items:center;gap:.4rem">
                    <i class="fas fa-code"></i> Demande envoyée à l'IA (meta-prompt)
                </span>
                <button id="copyMetaBtn" onclick="event.stopPropagation();copyMetaPrompt()" title="Copier"
                    style="background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.25);color:#a78bfa;border-radius:5px;padding:.2rem .5rem;cursor:pointer;font-size:.72rem;transition:.15s">
                    <i class="fas fa-copy"></i> Copier
                </button>
            </div>
            <div id="metaPromptBody" style="padding:.75rem .875rem">
                <pre id="metaPromptPre" style="background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:.75rem 1rem;font-size:.72rem;color:var(--text-secondary);white-space:pre-wrap;line-height:1.6;max-height:350px;overflow-y:auto;margin:0"></pre>
            </div>
        </div>

        <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
            <button id="suggestBtn" onclick="suggestPromptImagen()" class="btn btn-secondary" style="white-space:nowrap">
                <i class="fas fa-lightbulb"></i> Suggérer un prompt
            </button>
            <button id="imagenBtn" onclick="generateThumbnailImagen()" class="btn btn-primary" style="background:#f59e0b;border-color:#f59e0b;white-space:nowrap">
                <i class="fas fa-wand-magic-sparkles"></i> Générer l'image
            </button>
        </div>

        <div id="imagenProgress" style="display:none;margin-bottom:12px">
            <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-muted);margin-bottom:4px">
                <span id="imagenProgressLabel">Génération en cours…</span>
                <span id="imagenProgressPct">0%</span>
            </div>
            <div style="background:var(--bg-secondary);border-radius:999px;height:6px;overflow:hidden">
                <div id="imagenProgressBar" style="height:100%;width:0%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:999px;transition:width .4s ease"></div>
            </div>
        </div>

        <div id="imagenError" style="display:none;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:6px;padding:8px 12px;font-size:13px;color:#f87171;margin-bottom:10px"></div>

        <div id="imagenActions" style="display:none;gap:8px;flex-wrap:wrap">
            <button onclick="applyThumbnailImagen()" class="btn btn-primary" id="imagenApplyBtn">
                <i class="fas fa-check"></i> Appliquer comme miniature
            </button>
            <button onclick="generateThumbnailImagen()" class="btn btn-secondary" id="imagenRegenBtn">
                <i class="fas fa-redo"></i> Regénérer
            </button>
        </div>
        <div id="imagenSuccess" style="display:none;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);border-radius:6px;padding:8px 12px;font-size:13px;color:#4ade80;margin-top:10px"></div>
    </div>

    {# Meta History #}
    {% if meta_history|length > 1 %}
    <div class="section-card">
        <div class="section-header">
            <h3><i class="fas fa-history"></i> Historique titre &amp; description</h3>
            <span style="font-size:12px;color:var(--text-muted)">{{ meta_history|length }} versions</span>
        </div>
        <div class="meta-timeline">
            {% for entry in meta_history %}
            {% set s = entry.snapshot %}
            <div class="meta-entry {{ entry.is_current ? 'meta-current' : '' }} {{ entry.is_best is defined ? 'meta-best' : '' }}">
                <div class="meta-entry-left">
                    <div class="meta-dot {{ entry.is_current ? 'dot-blue' : (entry.is_best is defined ? 'dot-green' : '') }}"></div>
                    <div class="meta-line"></div>
                </div>
                <div class="meta-entry-body">
                    <div class="meta-entry-header">
                        <span class="meta-date">{{ entry.from|date('d/m/Y') }}</span>
                        {% if entry.is_current %}<span class="badge badge-blue">Actuel</span>{% endif %}
                        {% if entry.is_best is defined %}<span class="badge badge-green"><i class="fas fa-trophy" style="font-size:10px"></i> Meilleure perf</span>{% endif %}
                        {% if entry.days_active > 0 %}<span style="font-size:11px;color:var(--text-muted)">{{ entry.days_active }} jour{{ entry.days_active > 1 ? 's' : '' }} actif</span>{% endif %}
                    </div>
                    <div class="meta-title">{{ s.title }}</div>
                    {% if s.description %}
                    <div class="meta-desc">{{ s.description|slice(0, 160) }}{% if s.description|length > 160 %}…{% endif %}</div>
                    {% endif %}
                    {% if entry.total_views > 0 or entry.avg_ctr is not null %}
                    <div class="meta-stats">
                        {% if entry.avg_views_day > 0 %}
                        <span class="meta-stat"><i class="fas fa-eye"></i> <strong>{{ entry.avg_views_day|number_format(0, ',', ' ') }}</strong> vues/jour</span>
                        {% endif %}
                        {% if entry.total_views > 0 %}
                        <span class="meta-stat"><i class="fas fa-chart-bar"></i> {{ entry.total_views|number_format(0, ',', ' ') }} total</span>
                        {% endif %}
                        {% if entry.avg_ctr is not null %}
                        <span class="meta-stat"><i class="fas fa-mouse-pointer"></i> CTR {{ entry.avg_ctr }}%</span>
                        {% endif %}
                    </div>
                    {% else %}
                    <div style="font-size:12px;color:var(--text-muted);margin-top:6px">Pas encore de données pour cette période</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

</div>{# /tab-opti #}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        var chartData = {{ chart_data|json_encode|raw }};
        var retentionData = {{ retention_data|json_encode|raw }};
    </script>
    {{ encore_entry_script_tags('video_detail') }}
    <script>
    function suggestPromptImagen() {
        var btn      = document.getElementById('suggestBtn');
        var textarea = document.getElementById('imagenPrompt');
        var errorDiv = document.getElementById('imagenError');

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Analyse…';
        errorDiv.style.display = 'none';

        fetch('{{ path('analytics_video_suggest_prompt', {youtubeId: video.youtubeId}) }}', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-lightbulb"></i> Suggérer un prompt';
            if (data.success) {
                textarea.value = data.prompt;
                textarea.focus();
                // Show meta-prompt
                var details = document.getElementById('metaPromptDetails');
                var pre     = document.getElementById('metaPromptPre');
                if (details && pre && data.meta_prompt) {
                    pre.textContent = data.meta_prompt;
                    details.style.display = '';
                    var body = document.getElementById('metaPromptBody');
                    if (body) body.style.display = '';
                }
            } else {
                errorDiv.textContent   = data.message || 'Erreur inconnue.';
                errorDiv.style.display = '';
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-lightbulb"></i> Suggérer un prompt';
            errorDiv.textContent   = 'Erreur réseau.';
            errorDiv.style.display = '';
        });
    }

    var _imagenPollTimer    = null;
    var _imagenProgressPct = 0;
    var _imagenProgressTimer = null;

    function imagenProgressStart() {
        var bar  = document.getElementById('imagenProgressBar');
        var pct  = document.getElementById('imagenProgressPct');
        var lbl  = document.getElementById('imagenProgressLabel');
        var wrap = document.getElementById('imagenProgress');
        _imagenProgressPct = 0;
        wrap.style.display = '';
        bar.style.width    = '0%';
        pct.textContent    = '0%';
        lbl.textContent    = 'Démarrage…';
        bar.style.background = 'linear-gradient(90deg,#f59e0b,#fbbf24)';

        // Slow crawl up to 88% while waiting for the background job
        _imagenProgressTimer = setInterval(function() {
            if (_imagenProgressPct >= 88) return;
            _imagenProgressPct += (_imagenProgressPct < 40 ? 3 : _imagenProgressPct < 70 ? 1.5 : 0.5);
            bar.style.width = Math.min(_imagenProgressPct, 88) + '%';
            pct.textContent = Math.round(Math.min(_imagenProgressPct, 88)) + '%';
            var labels = ['Initialisation…','Envoi au modèle…','Génération en cours…','Rendu de l\'image…','Finalisation…'];
            lbl.textContent = labels[Math.min(Math.floor(_imagenProgressPct / 20), labels.length - 1)];
        }, 600);
    }

    function imagenProgressDone(success) {
        clearInterval(_imagenProgressTimer);
        var bar  = document.getElementById('imagenProgressBar');
        var pct  = document.getElementById('imagenProgressPct');
        var lbl  = document.getElementById('imagenProgressLabel');
        var wrap = document.getElementById('imagenProgress');
        if (success) {
            bar.style.background = 'linear-gradient(90deg,#22c55e,#4ade80)';
            bar.style.width = '100%'; pct.textContent = '100%'; lbl.textContent = 'Terminé !';
            setTimeout(function() { wrap.style.display = 'none'; bar.style.background = 'linear-gradient(90deg,#f59e0b,#fbbf24)'; bar.style.width = '0%'; }, 1200);
        } else {
            bar.style.background = 'linear-gradient(90deg,#ef4444,#f87171)';
            bar.style.width = '100%'; pct.textContent = '—'; lbl.textContent = 'Échec';
            setTimeout(function() { wrap.style.display = 'none'; bar.style.background = 'linear-gradient(90deg,#f59e0b,#fbbf24)'; bar.style.width = '0%'; }, 2500);
        }
    }

    function generateThumbnailImagen() {
        var btn         = document.getElementById('imagenBtn');
        var regenBtn    = document.getElementById('imagenRegenBtn');
        var textarea    = document.getElementById('imagenPrompt');
        var errorDiv    = document.getElementById('imagenError');
        var previewImg  = document.getElementById('imagenPreviewImg');
        var placeholder = document.getElementById('imagenPreviewPlaceholder');
        var actions     = document.getElementById('imagenActions');
        var successDiv  = document.getElementById('imagenSuccess');

        if (!textarea.value.trim()) {
            errorDiv.textContent   = 'Saisissez un prompt ou cliquez sur « Suggérer un prompt » d\'abord.';
            errorDiv.style.display = '';
            return;
        }

        btn.disabled = true;
        if (regenBtn) regenBtn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Génération…';
        errorDiv.style.display    = 'none';
        successDiv.style.display  = 'none';
        actions.style.display     = 'none';
        previewImg.style.display  = 'none';
        placeholder.style.display = '';
        imagenProgressStart();

        // Step 1: start the background job (returns immediately)
        fetch('{{ path('analytics_video_generate_thumbnail', {youtubeId: video.youtubeId}) }}', {
            method:  'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body:    'prompt=' + encodeURIComponent(textarea.value.trim()),
        })
        .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(function(data) {
            if (!data.success) {
                imagenProgressDone(false);
                btn.disabled = false; if (regenBtn) regenBtn.disabled = false;
                btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i> Générer l\'image';
                errorDiv.textContent = data.message || 'Erreur inconnue.';
                errorDiv.style.display = '';
                return;
            }
            // Step 2: poll for result
            imagenPoll(data.jobId, btn, regenBtn, previewImg, placeholder, actions, errorDiv);
        })
        .catch(function(err) {
            imagenProgressDone(false);
            btn.disabled = false; if (regenBtn) regenBtn.disabled = false;
            btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i> Générer l\'image';
            errorDiv.textContent = 'Erreur de démarrage : ' + (err.message || 'inconnue') + '.';
            errorDiv.style.display = '';
        });
    }

    function imagenPoll(jobId, btn, regenBtn, previewImg, placeholder, actions, errorDiv) {
        var attempts = 0;
        var maxAttempts = 60; // 2 min at 2s interval

        clearInterval(_imagenPollTimer);
        _imagenPollTimer = setInterval(function() {
            attempts++;
            if (attempts > maxAttempts) {
                clearInterval(_imagenPollTimer);
                imagenProgressDone(false);
                btn.disabled = false; if (regenBtn) regenBtn.disabled = false;
                btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i> Générer l\'image';
                errorDiv.textContent = 'La génération a dépassé 2 minutes. Le modèle est peut-être surchargé — réessayez.';
                errorDiv.style.display = '';
                return;
            }

            fetch('{{ path('analytics_video_thumbnail_status', {youtubeId: video.youtubeId, jobId: '__JOB__'}) }}'.replace('__JOB__', jobId))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.status === 'pending') return; // keep polling
                clearInterval(_imagenPollTimer);
                btn.disabled = false; if (regenBtn) regenBtn.disabled = false;
                btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i> Générer l\'image';
                if (data.status === 'done') {
                    imagenProgressDone(true);
                    previewImg.src = data.url + '?t=' + Date.now();
                    previewImg.style.display  = '';
                    placeholder.style.display = 'none';
                    actions.style.display     = 'flex';
                } else {
                    imagenProgressDone(false);
                    errorDiv.textContent   = data.message || 'Erreur de génération.';
                    errorDiv.style.display = '';
                }
            })
            .catch(function() { /* ignore poll errors, keep trying */ });
        }, 2000);
    }

    function applyThumbnailImagen() {
        var applyBtn   = document.getElementById('imagenApplyBtn');
        var errorDiv   = document.getElementById('imagenError');
        var successDiv = document.getElementById('imagenSuccess');

        applyBtn.disabled = true;
        applyBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Application…';
        errorDiv.style.display   = 'none';
        successDiv.style.display = 'none';

        fetch('{{ path('analytics_video_apply_thumbnail', {youtubeId: video.youtubeId}) }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            applyBtn.disabled = false;
            applyBtn.innerHTML = '<i class="fas fa-check"></i> Appliquer comme miniature';
            if (data.success) {
                // Update header thumbnail
                var headerThumb = document.getElementById('headerThumbnail');
                if (headerThumb) headerThumb.src = data.url + '?t=' + Date.now();
                successDiv.textContent   = data.message || 'Miniature appliquée.';
                successDiv.style.display = '';
                if (window.showToast) window.showToast(data.message, 'success');
            } else {
                if (data.reauth) {
                    errorDiv.innerHTML = (data.message || 'Erreur inconnue.')
                        + ' <a href="{{ path('auth_google') }}?force_consent=1" style="color:#f87171;text-decoration:underline;font-weight:600">→ Reconnecter maintenant</a>';
                } else {
                    errorDiv.textContent = data.message || 'Erreur inconnue.';
                }
                errorDiv.style.display = '';
            }
        })
        .catch(function() {
            applyBtn.disabled = false;
            applyBtn.innerHTML = '<i class="fas fa-check"></i> Appliquer comme miniature';
            errorDiv.textContent   = 'Erreur réseau.';
            errorDiv.style.display = '';
        });
    }

    function copyMetaPrompt() {
        var pre = document.getElementById('metaPromptPre');
        var btn = document.getElementById('copyMetaBtn');
        if (!pre || !btn) return;
        var text = pre.textContent;
        var done = function() {
            var orig = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i> Copié';
            btn.style.color = '#22c55e';
            setTimeout(function() { btn.innerHTML = orig; btn.style.color = ''; }, 1800);
        };
        if (navigator.clipboard) { navigator.clipboard.writeText(text).then(done); }
        else {
            var ta = document.createElement('textarea');
            ta.value = text; ta.style.cssText = 'position:fixed;opacity:0';
            document.body.appendChild(ta); ta.select(); document.execCommand('copy');
            document.body.removeChild(ta); done();
        }
    }

    function triggerAnalysis(type) {
        var statusEls = ['aiAnalysisStatus', 'aiAnalysisStatusOpti']
            .map(function(id) { return document.getElementById(id); })
            .filter(Boolean);

        statusEls.forEach(function(el) {
            el.style.display = '';
            el.style.color   = 'var(--text-muted)';
            el.innerHTML     = '<i class="fas fa-spinner fa-spin"></i> Analyse en cours…';
        });

        var body = new URLSearchParams();
        if (type) body.append('type', type);

        fetch('{{ path('analytics_video_trigger_analysis', {youtubeId: video.youtubeId}) }}', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
            body: body.toString()
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success) {
                statusEls.forEach(function(el) {
                    el.style.color   = '#ef4444';
                    el.textContent   = '✗ ' + (data.message || 'Erreur');
                });
                return;
            }
            var attempts = 0;
            var pollUrl = '{{ path('analytics_video_analysis_status', {youtubeId: video.youtubeId, jobId: '__JOB__'}) }}'
                .replace('__JOB__', data.jobId);
            var poll = setInterval(function() {
                attempts++;
                fetch(pollUrl)
                    .then(function(r) { return r.json(); })
                    .then(function(status) {
                        if (status.status === 'pending' && attempts < 90) return;
                        clearInterval(poll);
                        var ok = status.status === 'done';
                        statusEls.forEach(function(el) {
                            el.style.color = ok ? '#22c55e' : '#ef4444';
                            el.textContent = ok
                                ? '✓ ' + status.message + ' — rechargement…'
                                : '✗ ' + (status.message || 'Erreur');
                        });
                        if (ok) setTimeout(function() { window.location.reload(); }, 1500);
                    })
                    .catch(function() { if (attempts >= 90) clearInterval(poll); });
            }, 2000);
        })
        .catch(function() {
            statusEls.forEach(function(el) {
                el.style.color = '#ef4444';
                el.textContent = '✗ Erreur réseau';
            });
        });
    }
    </script>
{% endblock %}
