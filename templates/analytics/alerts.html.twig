{% extends 'base.html.twig' %}

{% block title %}Alertes intelligentes — YouTube Analyse{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1><i class="fas fa-bell" style="color:var(--blue)"></i> Alertes intelligentes</h1>
        <span class="last-sync">
            {{ urgent|length }} urgent{{ urgent|length > 1 ? 's' : '' }} ·
            {{ conseil|length }} conseil{{ conseil|length > 1 ? 's' : '' }}
            {% if smart_alerts is defined and smart_alerts|length > 0 %} · {{ smart_alerts|length }} opportunité{{ smart_alerts|length > 1 ? 's' : '' }}{% endif %}
        </span>
    </div>
    <div class="header-actions">
        <a href="{{ path('priority_actions') }}" class="btn btn-outline btn-sm">
            <i class="fas fa-fire"></i> Actions prioritaires
        </a>
    </div>
</div>

{% set total = urgent|length + conseil|length + (smart_alerts is defined ? smart_alerts|length : 0) %}

{% if total == 0 %}
<div class="section-card">
    <div class="empty-state">
        <i class="fas fa-check-circle fa-3x" style="color:var(--green)"></i>
        <h3>Aucune action en attente</h3>
        <p>Lance <strong>app:ai:analyze</strong> pour générer de nouvelles recommandations.</p>
    </div>
</div>
{% else %}

<div class="action-filters" id="actionFilters">
    <button class="action-filter-btn" data-filter="all">Tout <strong>{{ total }}</strong></button>
    {% if smart_alerts is defined and smart_alerts|length > 0 %}
    <button class="action-filter-btn smart" data-filter="smart">⚡ Opportunités <strong>{{ smart_alerts|length }}</strong></button>
    {% endif %}
    {% if urgent|length > 0 %}
    <button class="action-filter-btn urgent" data-filter="urgent">🔴 Urgent <strong>{{ urgent|length }}</strong></button>
    {% endif %}
    {% if conseil|length > 0 %}
    <button class="action-filter-btn conseil" data-filter="conseil">🟡 Conseil <strong>{{ conseil|length }}</strong></button>
    {% endif %}
</div>

<div class="actions-list" id="actionsList">

    {# ── Smart alerts (algorithmic) ──────────────────────────────────────── #}
    {% if smart_alerts is defined %}
    {% for alert in smart_alerts %}
    <div class="action-card urgency-smart" data-urgency="smart" data-id="smart-{{ loop.index }}">
        <div class="action-card-header">
            <div class="action-urgency-icon smart" style="background:{{ alert.color }}18;color:{{ alert.color }}">
                <i class="fas {{ alert.icon }}"></i>
            </div>
            <div style="flex:1;min-width:0">
                <div class="action-card-title">{{ alert.title }}</div>
                {% if alert.video is defined %}
                <div class="action-card-video" title="{{ alert.video.title }}">
                    <i class="fas fa-video" style="font-size:10px;margin-right:3px"></i>{{ alert.video.title|length > 60 ? alert.video.title|slice(0,60) ~ '…' : alert.video.title }}
                </div>
                {% endif %}
            </div>
            <span class="action-card-date" style="background:{{ alert.color }}18;color:{{ alert.color }};padding:.2rem .5rem;border-radius:4px;font-size:.72rem;font-weight:600">Opportunité</span>
        </div>
        <div class="action-card-body">
            <p style="margin:0 0 6px">{{ alert.message }}</p>
            <p style="margin:0"><i class="fas fa-arrow-right" style="color:{{ alert.color }};font-size:11px;margin-right:4px"></i>{{ alert.action }}</p>
        </div>
        <div class="action-card-footer">
            {% if alert.video is defined %}
            <a href="{{ path('analytics_video_detail', {youtubeId: alert.video.youtubeId}) }}" class="btn btn-outline btn-sm">
                <i class="fas fa-chart-line"></i> Voir la vidéo
            </a>
            {% endif %}
            <button class="btn-dismiss" onclick="dismissAction(this, 'smart-{{ loop.index }}')"><i class="fas fa-check"></i> Fait</button>
        </div>
    </div>
    {% endfor %}
    {% endif %}

    {% for report in urgent %}
    {% set p = report.payload %}
    <div class="action-card urgency-urgent" data-urgency="urgent" data-id="{{ report.id }}">
        <div class="action-card-header">
            <div class="action-urgency-icon urgent"><i class="fas fa-exclamation"></i></div>
            <div style="flex:1;min-width:0">
                <div class="action-card-title">
                    {{ p.type == 'surperformance' ? 'Surperformance détectée' : 'Sous-performance détectée' }}
                </div>
                {% if report.video %}
                <div class="action-card-video" title="{{ report.video.title }}">
                    <i class="fas fa-video" style="font-size:10px;margin-right:3px"></i>{{ report.video.title }}
                </div>
                {% endif %}
            </div>
            <div class="action-card-date">{{ report.generatedAt|date('d/m/Y') }}</div>
        </div>
        <div class="action-card-body">
            <p style="margin:0 0 6px"><strong>Cause :</strong> {{ p.cause_probable }}</p>
            <p style="margin:0"><i class="fas fa-lightbulb" style="color:var(--yellow);margin-right:4px"></i>{{ p.action_recommandee }}</p>
        </div>
        <div class="action-card-footer">
            {% if report.video %}
            <a href="{{ path('analytics_video_detail', {youtubeId: report.video.youtubeId}) }}" class="btn btn-outline btn-sm">
                <i class="fas fa-chart-line"></i> Voir la vidéo
            </a>
            {% endif %}
            <button class="btn-dismiss" onclick="dismissAction(this, {{ report.id }})"><i class="fas fa-check"></i> Fait</button>
        </div>
    </div>
    {% endfor %}

    {% for report in conseil %}
    {% set p = report.payload %}
    <div class="action-card urgency-conseil" data-urgency="conseil" data-id="{{ report.id }}">
        <div class="action-card-header">
            <div class="action-urgency-icon conseil"><i class="fas fa-lightbulb"></i></div>
            <div style="flex:1;min-width:0">
                <div class="action-card-title">
                    {% if report.type.value == 'title_optimization' %}Optimisation du titre
                    {% elseif report.type.value == 'seo_optimization' %}Amélioration SEO
                    {% elseif report.type.value == 'comment_analysis' %}Feedback audience
                    {% elseif report.type.value == 'prediction' %}Prévision de performance
                    {% else %}Recommandation IA{% endif %}
                </div>
                {% if report.video %}
                <div class="action-card-video" title="{{ report.video.title }}">
                    <i class="fas fa-video" style="font-size:10px;margin-right:3px"></i>{{ report.video.title }}
                </div>
                {% endif %}
            </div>
            <div class="action-card-date">{{ report.generatedAt|date('d/m/Y') }}</div>
        </div>
        <div class="action-card-body">
            {% if p.diagnostic is defined %}
            <p style="margin:0 0 4px">{{ p.diagnostic }}</p>
            {% elseif p.resume is defined %}
            <p style="margin:0 0 4px">{{ p.resume }}</p>
            {% elseif p.facteurs is defined %}
            <p style="margin:0 0 4px">{{ p.facteurs|first }}</p>
            {% endif %}
            {% if p.action_recommandee is defined %}
            <p style="margin:4px 0 0"><i class="fas fa-arrow-right" style="color:var(--yellow);font-size:11px;margin-right:4px"></i>{{ p.action_recommandee }}</p>
            {% elseif p.suggestions_titres is defined and p.suggestions_titres|length > 0 %}
            <p style="margin:4px 0 0"><i class="fas fa-arrow-right" style="color:var(--yellow);font-size:11px;margin-right:4px"></i>Titre suggéré : <em>{{ p.suggestions_titres|first }}</em></p>
            {% endif %}
        </div>
        <div class="action-card-footer">
            {% if report.video %}
            <a href="{{ path('analytics_video_detail', {youtubeId: report.video.youtubeId}) }}" class="btn btn-outline btn-sm">
                <i class="fas fa-chart-line"></i> Voir la vidéo
            </a>
            {% endif %}
            <button class="btn-dismiss" onclick="dismissAction(this, {{ report.id }})"><i class="fas fa-check"></i> Fait</button>
        </div>
    </div>
    {% endfor %}

</div>
{% endif %}

<style>
.action-filter-btn.smart { color:#22c55e; }
.action-filter-btn.smart.active { background:rgba(34,197,94,.12); color:#22c55e; border-color:rgba(34,197,94,.3); }
.urgency-smart { border-left-color: #22c55e; }
.action-urgency-icon.smart { border-radius:50%; width:32px; height:32px; display:flex; align-items:center; justify-content:center; }
</style>

<script>
(function() {
    var dismissed = JSON.parse(localStorage.getItem('dismissed_actions') || '[]');
    dismissed.forEach(function(id) {
        var card = document.querySelector('[data-id="' + id + '"]');
        if (card) card.classList.add('dismissed');
    });

    window.dismissAction = function(btn, id) {
        dismissed.push(id);
        localStorage.setItem('dismissed_actions', JSON.stringify(dismissed));
        var card = btn.closest('.action-card');
        card.style.transition = 'opacity .3s, max-height .4s';
        card.style.opacity = '0';
        card.style.maxHeight = card.offsetHeight + 'px';
        setTimeout(function() { card.style.maxHeight = '0'; card.style.padding = '0'; card.style.margin = '0'; card.style.overflow = 'hidden'; }, 50);
        setTimeout(function() { card.remove(); }, 450);
    };

    function applyFilter(filter) {
        document.querySelectorAll('.action-filter-btn').forEach(function(b) {
            b.classList.toggle('active', b.dataset.filter === filter);
        });
        document.querySelectorAll('.action-card').forEach(function(card) {
            card.style.display = (filter === 'all' || card.dataset.urgency === filter) ? '' : 'none';
        });
        var url = new URL(window.location.href);
        if (filter === 'all') { url.searchParams.delete('filter'); }
        else { url.searchParams.set('filter', filter); }
        history.replaceState(null, '', url.toString());
    }

    // Init from URL param
    var params  = new URLSearchParams(window.location.search);
    var initial = params.get('filter') || 'all';
    applyFilter(initial);

    document.getElementById('actionFilters') && document.getElementById('actionFilters').addEventListener('click', function(e) {
        var btn = e.target.closest('.action-filter-btn');
        if (!btn) return;
        applyFilter(btn.dataset.filter);
    });
})();
</script>
{% endblock %}
