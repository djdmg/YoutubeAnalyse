{% extends 'base.html.twig' %}

{% block title %}Coûts IA — YouTube Analyse{% endblock %}

{% block body %}
<div class="dashboard-header">
    <div>
        <h1><i class="fas fa-robot"></i> Coûts IA</h1>
        <span class="last-sync">Claude · Gemini · estimation standard</span>
    </div>
</div>

{% if missing_pricing_models|length > 0 %}
<div class="alert alert-warning" style="margin-bottom:1rem">
    Tarif non configuré pour {{ missing_pricing_models|join(', ') }}. Ces lignes sont exclues des totaux estimés.
</div>
{% endif %}

{# Monthly Summary #}
<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(59,130,246,0.15);color:#3b82f6"><i class="fas fa-coins"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">${{ cost_usd }}</div>
            <div class="kpi-label">Coût réel ce mois (J{{ day_of_month }}/{{ days_in_month }})</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(234,179,8,0.15);color:#eab308"><i class="fas fa-chart-line"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">${{ forecast_usd }}</div>
            <div class="kpi-label">
                Prévision fin de mois
                <span style="font-size:0.7rem;opacity:0.6;display:block">
                    {{ forecast_basis == 'last_month' ? 'base : mois précédent' : 'base : cadence actuelle' }}
                </span>
            </div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(168,85,247,0.15);color:#a855f7"><i class="fas fa-arrow-right"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ input_tokens|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Tokens input (mois)</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(249,115,22,0.15);color:#f97316"><i class="fas fa-arrow-left"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ output_tokens|number_format(0, ',', ' ') }}</div>
            <div class="kpi-label">Tokens output (mois)</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(34,197,94,0.15);color:#22c55e"><i class="fas fa-check"></i></div>
        <div class="kpi-content">
            <div class="kpi-value">{{ monthly.success_calls ?? 0 }} / {{ monthly.total_calls ?? 0 }}</div>
            <div class="kpi-label">Appels réussis (mois)</div>
        </div>
    </div>
</div>

{# Breakdown par modèle #}
{% if by_model|length > 0 %}
<div class="section-card" style="margin-bottom:1.5rem">
    <div class="section-header">
        <h3><i class="fas fa-microchip"></i> Coût par modèle (mois en cours)</h3>
    </div>
    <div class="videos-table-wrapper">
        <table class="videos-table">
            <thead>
                <tr>
                    <th>Modèle</th>
                    <th>Appels</th>
                    <th>Tokens input</th>
                    <th>Tokens output</th>
                    <th>Tarif input</th>
                    <th>Tarif output</th>
                    <th>Coût estimé</th>
                </tr>
            </thead>
            <tbody>
                {% for row in by_model %}
                {% set p = pricing[row.model] ?? null %}
                {% set rowCost = p ? (row.tokens_input / 1000000 * p.input) + (row.tokens_output / 1000000 * p.output) : null %}
                <tr>
                    <td><code>{{ row.model }}</code></td>
                    <td class="num">{{ row.calls }}</td>
                    <td class="num">{{ row.tokens_input|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ row.tokens_output|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ p ? '$' ~ p.input ~ '/M' : '—' }}</td>
                    <td class="num">{{ p ? '$' ~ p.output ~ '/M' : '—' }}</td>
                    <td class="num"><strong>{{ rowCost is not null ? '$' ~ rowCost|number_format(4, '.') : 'Non estimé' }}</strong></td>
                </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="6" style="text-align:right;font-weight:600">Total</td>
                    <td class="num"><strong>${{ cost_usd }}</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
{% endif %}

{# Table #}
<div class="section-card">
    <div class="section-header">
        <h3><i class="fas fa-history"></i> Historique des appels</h3>
        <a href="{{ path('analytics_ai_costs') }}?export=csv" class="btn btn-outline btn-sm">
            <i class="fas fa-download"></i> Export CSV
        </a>
    </div>
    {% if reports|length == 0 %}
    <div class="empty-state">
        <i class="fas fa-robot fa-3x"></i>
        <h3>Aucun appel IA</h3>
        <p>Lance <strong>app:ai:analyze</strong> pour générer des rapports.</p>
    </div>
    {% else %}
    <div class="videos-table-wrapper">
        <table class="videos-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Vidéo</th>
                    <th>Tokens input</th>
                    <th>Tokens output</th>
                    <th>Durée</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for report in reports %}
                <tr>
                    <td>{{ report.generatedAt|date('d/m/Y H:i') }}</td>
                    <td><span class="badge badge-blue">{{ report.type.label() }}</span></td>
                    <td>{{ report.video ? (report.video.title|length > 40 ? report.video.title|slice(0,40) ~ '…' : report.video.title) : '—' }}</td>
                    <td class="num">{{ report.tokensInput ? report.tokensInput|number_format(0, ',', ' ') : '—' }}</td>
                    <td class="num">{{ report.tokensOutput ? report.tokensOutput|number_format(0, ',', ' ') : '—' }}</td>
                    <td class="num">{{ report.durationMs ? report.durationMs ~ ' ms' : '—' }}</td>
                    <td>
                        <span class="badge {{ report.status.value == 'done' ? 'badge-green' : (report.status.value == 'failed' ? 'badge-red' : 'badge-yellow') }}">
                            {{ report.status.value }}
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
